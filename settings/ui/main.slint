// ── Data structs ─────────────────────────────────────────────────────────────

struct KeyData {
    base: string,
    english: string,
    w: float,
    is-modifier: bool,
}

struct LayoutEntry {
    code: string,
    variant: string,
    description: string,
}

struct ModelEntry {
    label: string,
    size: string,
    note: string,
    english-only: bool,
}

struct MonitorInfo {
    id: int,
    name: string,
    description: string,
    width: int,
    height: int,
    refresh-rate: float,
    pos-x: int,
    pos-y: int,
    scale: float,
    enabled: bool,
    is-primary: bool,
    canvas-x: float,
    canvas-y: float,
    canvas-w: float,
    canvas-h: float,
    available-modes: [string],
    current-mode-index: int,
}

struct SearchResult {
    label: string,
    tab-name: string,
    tab-index: int,
}

struct BindingEntry {
    idx: int,
    combo: string,
    description: string,
    dispatcher: string,
    args: string,
    section: string,
    submap: string,
    is-exec: bool,
}

/// A startup app or daemon shown in the Startup tab.
struct StartupEntry {
    name: string,
    command: string,
    source: string,
    enabled: bool,
    toggleable: bool,
    description: string,
}

/// An installable app that can be added to autostart.
struct AvailableAppEntry {
    name: string,
    exec: string,
    desktop-file: string,
    description: string,
}

/// A discovered Wi-Fi access point (mirrors wifi::WifiNetwork on the Rust side).
struct WifiEntry {
    ssid: string,
    /// Signal strength 0–100.
    signal: int,
    /// Security string: "WPA2", "WPA3", "WPA2 WPA3", "WEP", or "Open".
    security: string,
    /// True when this is the currently active connection.
    connected: bool,
    /// True when a saved NetworkManager profile exists for this SSID.
    saved: bool,
}

// ── Theme ────────────────────────────────────────────────────────────────────

export global Theme {
    in property <color> bg: #1e1e2e;
    in property <color> fg: #cdd6f4;
    in property <color> fg_dim: #a6adc8;
    in property <color> accent: #89b4fa;
    in property <color> bg_light: #45475a;
    in property <color> bg_lighter: #585b70;
    in property <color> danger: #f38ba8;
    in property <color> success: #a6e3a1;
    in property <color> warning: #f9e2af;
    in property <color> info: #94e2d5;
    in property <float> opacity: 0.40;
}

// ── Key cap component ────────────────────────────────────────────────────────

component KeyCap inherits Rectangle {
    in property <string> base;
    in property <string> english;
    in property <float> w: 1.0;
    in property <bool> is-modifier: false;

    height: 38px;
    width: Math.max(38px, 38px * root.w + (root.w - 1) * 3px);
    border-radius: 4px;
    background: root.is-modifier ? Theme.bg_lighter.transparentize(40%) : Theme.bg_light;

    VerticalLayout {
        padding: 2px;
        padding-left: 4px;

        if root.english != "": Text {
            text: root.english;
            color: Theme.fg_dim;
            font-size: 8px;
            overflow: elide;
        }

        Text {
            text: root.base;
            color: root.is-modifier ? Theme.fg_dim : Theme.fg;
            font-size: root.is-modifier ? 10px : 13px;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

// ── Sidebar tab button ───────────────────────────────────────────────────────

component TabButton inherits Rectangle {
    in property <string> label;
    in property <string> icon;
    in property <bool> active: false;
    callback clicked();

    height: 36px;
    border-radius: 4px;
    background: active ? Theme.accent.transparentize(70%)
        : tab-touch.has-hover ? Theme.bg_lighter : transparent;

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 12px;
        spacing: 8px;
        alignment: start;

        VerticalLayout {
            alignment: center;
            width: 3px;
            Rectangle {
                width: 3px;
                height: 20px;
                border-radius: 2px;
                background: active ? Theme.accent : transparent;
            }
        }

        Text {
            text: root.icon;
            color: active ? Theme.accent : Theme.fg_dim;
            font-size: 14px;
            vertical-alignment: center;
            width: 18px;
        }

        Text {
            text: root.label;
            color: active ? Theme.fg : Theme.fg_dim;
            font-size: 12px;
            font-weight: active ? 600 : 400;
            vertical-alignment: center;
        }
    }

    tab-touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

// ── Display dropdown (resolution picker) ─────────────────────────────────────

component ResDropdown inherits Rectangle {
    in property <[string]> model: [];
    in-out property <int> current-index: 0;
    in-out property <bool> open: false;
    callback selected(int);

    height: 28px;
    border-radius: 4px;
    background: Theme.bg_light;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;

        Text {
            text: model.length > 0 && current-index >= 0 && current-index < model.length
                ? model[current-index] : "---";
            color: Theme.fg;
            font-size: 11px;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }

        Text {
            text: root.open ? "\u{25b2}" : "\u{25bc}";
            color: Theme.fg_dim;
            font-size: 8px;
            vertical-alignment: center;
            width: 16px;
            horizontal-alignment: center;
        }
    }

    drop-touch := TouchArea {
        clicked => { root.open = !root.open; }
    }

    if root.open: Rectangle {
        x: 0;
        y: parent.height + 2px;
        width: parent.width;
        height: min(200px, root.model.length * 26px + 4px);
        border-radius: 4px;
        background: Theme.bg_light;
        border-width: 1px;
        border-color: Theme.bg_lighter;
        drop-shadow-blur: 8px;
        drop-shadow-color: #00000066;

        Flickable {
            x: 2px;
            y: 2px;
            width: parent.width - 4px;
            height: parent.height - 4px;
            viewport-width: self.width;

            VerticalLayout {
                spacing: 0;
                for item[idx] in root.model: Rectangle {
                    height: 26px;
                    border-radius: 3px;
                    background: idx == root.current-index ? Theme.accent
                              : opt-touch.has-hover ? Theme.bg_lighter
                              : transparent;

                    Text {
                        text: item;
                        color: idx == root.current-index ? Theme.bg : Theme.fg;
                        font-size: 11px;
                        vertical-alignment: center;
                        x: 6px;
                    }

                    opt-touch := TouchArea {
                        clicked => {
                            root.current-index = idx;
                            root.open = false;
                            root.selected(idx);
                        }
                    }
                }
            }
        }
    }
}

// ── Scale slider ─────────────────────────────────────────────────────────────

component ThemeSlider inherits Rectangle {
    in-out property <float> value: 1.0;
    in property <float> minimum: 0.5;
    in property <float> maximum: 3.0;
    callback changed(float);

    height: 20px;

    Rectangle {
        y: (parent.height - 4px) / 2;
        height: 4px;
        border-radius: 2px;
        background: Theme.bg_lighter;

        Rectangle {
            width: parent.width * ((root.value - root.minimum) / (root.maximum - root.minimum));
            height: parent.height;
            border-radius: parent.border-radius;
            background: Theme.accent;
        }
    }

    Rectangle {
        x: (parent.width - 14px) * ((root.value - root.minimum) / (root.maximum - root.minimum));
        y: (parent.height - 14px) / 2;
        width: 14px;
        height: 14px;
        border-radius: 7px;
        background: slider-touch.pressed ? Theme.accent.darker(0.2) : Theme.accent;
        drop-shadow-blur: 3px;
        drop-shadow-color: #00000044;
    }

    slider-touch := TouchArea {
        moved => {
            if (self.pressed) {
                root.value = clamp(root.minimum + (self.mouse-x / root.width) * (root.maximum - root.minimum), root.minimum, root.maximum);
                root.value = round(root.value * 4) / 4;
                root.changed(root.value);
            }
        }
        pointer-event(event) => {
            if (event.kind == PointerEventKind.down) {
                root.value = clamp(root.minimum + (self.mouse-x / root.width) * (root.maximum - root.minimum), root.minimum, root.maximum);
                root.value = round(root.value * 4) / 4;
                root.changed(root.value);
            }
        }
    }
}

// ── Draggable monitor rectangle ──────────────────────────────────────────────

component MonitorRect inherits Rectangle {
    in property <string> label;
    in property <string> sublabel;
    in property <bool> selected;
    in property <bool> is-primary;

    in property <float> base-x;
    in property <float> base-y;
    in-out property <float> offset-x: 0;
    in-out property <float> offset-y: 0;
    private property <bool> dragging: false;

    callback clicked();
    callback drag-finished(float, float);

    x: (base-x + offset-x) * 1px;
    y: (base-y + offset-y) * 1px;

    border-radius: 6px;
    border-width: selected ? 2px : 1px;
    border-color: selected ? Theme.accent : Theme.bg_lighter;
    background: dragging ? Theme.bg_lighter
              : selected ? Theme.bg_light
              : Theme.bg_light.darker(0.3);
    drop-shadow-blur: dragging ? 12px : selected ? 8px : 2px;
    drop-shadow-color: #00000066;

    VerticalLayout {
        alignment: center;
        padding: 8px;

        Text {
            text: label;
            color: Theme.fg;
            font-size: 14px;
            font-weight: 700;
            horizontal-alignment: center;
        }

        Text {
            text: sublabel;
            color: Theme.fg_dim;
            font-size: 10px;
            horizontal-alignment: center;
        }

        if is-primary: Text {
            text: "Primary";
            color: Theme.accent;
            font-size: 9px;
            font-weight: 600;
            horizontal-alignment: center;
        }
    }

    touch := TouchArea {
        mouse-cursor: root.dragging ? pointer : default;

        clicked => {
            if (!root.dragging) { root.clicked(); }
        }

        moved => {
            if (self.pressed) {
                root.dragging = true;
                root.offset-x += (self.mouse-x - self.pressed-x) / 1px;
                root.offset-y += (self.mouse-y - self.pressed-y) / 1px;
            }
        }

        pointer-event(event) => {
            if (event.kind == PointerEventKind.up) {
                if (root.dragging) {
                    root.drag-finished(root.base-x + root.offset-x,
                                       root.base-y + root.offset-y);
                }
                root.dragging = false;
                root.offset-x = 0;
                root.offset-y = 0;
            }
        }
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// SCROLL INDICATOR — thin scrollbar thumb overlay for Flickable
// ══════════════════════════════════════════════════════════════════════════════

component ScrollIndicator inherits Rectangle {
    in property <length> viewport-height;
    in property <length> viewport-y;
    in property <length> visible-height;

    property <float> ratio: self.visible-height <= 0px ? 1.0 :
        clamp(self.visible-height / max(self.viewport-height, 1px), 0.0, 1.0);
    property <float> scroll-frac: self.viewport-height <= self.visible-height ? 0.0 :
        clamp(-self.viewport-y / (self.viewport-height - self.visible-height), 0.0, 1.0);
    property <bool> needed: self.viewport-height > self.visible-height + 4px;

    width: 4px;
    visible: self.needed;
    opacity: 0.6;

    // Track
    Rectangle {
        width: 100%;
        height: 100%;
        border-radius: 2px;
        background: Theme.bg_lighter.transparentize(70%);
    }

    // Thumb
    Rectangle {
        x: 0px;
        y: parent.scroll-frac * (parent.height - self.height);
        width: 100%;
        height: max(20px, parent.height * parent.ratio);
        border-radius: 2px;
        background: Theme.fg_dim.transparentize(40%);
    }
}

// ── Horizontal scroll indicator ───────────────────────────────────────────────

component ScrollIndicatorH inherits Rectangle {
    in property <length> viewport-width;
    in property <length> viewport-x;
    in property <length> visible-width;

    property <float> ratio: self.visible-width <= 0px ? 1.0 :
        clamp(self.visible-width / max(self.viewport-width, 1px), 0.0, 1.0);
    property <float> scroll-frac: self.viewport-width <= self.visible-width ? 0.0 :
        clamp(-self.viewport-x / (self.viewport-width - self.visible-width), 0.0, 1.0);
    property <bool> needed: self.viewport-width > self.visible-width + 4px;

    height: 4px;
    visible: self.needed;
    opacity: 0.6;

    Rectangle {
        width: 100%;
        height: 100%;
        border-radius: 2px;
        background: Theme.bg_lighter.transparentize(70%);
    }

    Rectangle {
        y: 0px;
        x: parent.scroll-frac * (parent.width - self.width);
        height: 100%;
        width: max(20px, parent.width * parent.ratio);
        border-radius: 2px;
        background: Theme.fg_dim.transparentize(40%);
    }
}

// ── Wi-Fi signal strength bars ────────────────────────────────────────────────

component SignalBars inherits HorizontalLayout {
    in property <int> signal: 0;  // 0–100
    spacing: 2px;
    alignment: center;

    // Bar 1 — always shown (very weak)
    Rectangle {
        width: 4px; height: 8px; border-radius: 1px;
        background: signal >= 1 ? Theme.accent : Theme.bg_lighter;
    }
    // Bar 2 — fair
    Rectangle {
        width: 4px; height: 12px; border-radius: 1px;
        background: signal >= 30 ? Theme.accent : Theme.bg_lighter;
    }
    // Bar 3 — good
    Rectangle {
        width: 4px; height: 17px; border-radius: 1px;
        background: signal >= 55 ? Theme.accent : Theme.bg_lighter;
    }
    // Bar 4 — excellent
    Rectangle {
        width: 4px; height: 22px; border-radius: 1px;
        background: signal >= 75 ? Theme.accent : Theme.bg_lighter;
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// MAIN WINDOW
// ══════════════════════════════════════════════════════════════════════════════

export component MainWindow inherits Window {
    title: "Settings";
    preferred-width: 900px;
    preferred-height: 560px;
    min-width: 500px;
    min-height: 350px;
    no-frame: true;
    background: Theme.bg.transparentize(1.0 - Theme.opacity);

    // ── Tab state ──
    in-out property <int> active-tab: 0;

    // ── Deep-link highlight ──
    in property <string> highlight-setting: "";
    in-out property <bool> highlight-blink-on: false;

    // ── Keyboard tab properties ──
    in property <[KeyData]> row0;
    in property <[KeyData]> row1;
    in property <[KeyData]> row2;
    in property <[KeyData]> row3;
    in property <[KeyData]> row4;
    in property <string> layout-name: "Loading...";
    in property <[string]> available-layouts;
    in-out property <[LayoutEntry]> active-layouts;
    in property <bool> loading: true;

    property <bool> dropdown-open: false;
    in-out property <int> selected-dropdown-index: -1;
    property <int> highlighted-dropdown-index: 0;
    property <string> search-text: "";
    property <bool> show-help: false;
    property <string> global-search-text: "";
    property <int> search-selected-index: 0;
    in property <[SearchResult]> search-results;

    // ── Dictation tab properties ──
    in property <bool> dictation-installed: false;
    in property <string> dictation-language: "unknown";
    in property <string> dictation-model: "unknown";
    in property <bool> dictation-service-running: false;
    in property <bool> dictation-installing: false;
    in property <bool> dictation-install-error: false;
    in property <float> dictation-progress: 0;
    in property <string> dictation-progress-text: "Starting...";
    in-out property <bool> dictation-configuring: false;
    in property <[string]> dictation-lang-list;
    in property <string> dictation-selected-lang-name: "English (recommended)";
    in property <bool> dictation-show-also-english: false;
    property <bool> dictation-lang-dropdown-open: false;
    property <string> dictation-lang-search: "";
    property <int> dictation-lang-highlighted-idx: 0;
    in property <[ModelEntry]> dictation-model-list;
    in-out property <int> dictation-selected-model-idx: 0;
    in-out property <bool> dictation-also-english: true;
    in property <bool> dictation-config-missing: false;
    property <bool> dictation-selected-lang-is-english:
        root.dictation-selected-lang-name == "English (recommended)";

    // ── Display tab properties ──
    in property <[MonitorInfo]> disp-monitors: [];
    in-out property <int> disp-selected-index: -1;
    in property <[string]> disp-selected-modes: [];
    in-out property <int> disp-selected-mode-index: 0;
    in-out property <float> disp-selected-scale: 1.0;
    in property <string> disp-status-text: "Ready";
    in property <bool> disp-has-changes: false;
    in-out property <bool> disp-window-guard: true;

    // ── Power tab properties ──
    in-out property <int> power-profile-index: 1;
    in-out property <int> idle-lock-index: 2;      // 0=1m 1=5m 2=10m 3=30m 4=Never 5+=custom(1h,2h,3h,5h,8h)
    in-out property <int> idle-dpms-index: 2;       // same
    in-out property <int> idle-suspend-index: 2;    // same
    in-out property <int> idle-shutdown-index: 4;   // same (default Never)
    in property <bool> power-profiles-available: true;

    // ── About tab properties ──
    in property <string> app-version: "dev";
    in property <string> about-version: "dev";
    in property <string> about-kernel: "";
    in property <string> about-uptime: "";
    in property <string> about-hostname: "smplOS";
    in property <string> about-cpu: "";
    in property <string> about-ram: "";
    in property <string> about-gpu: "";

    // ── Keybindings tab properties ──
    in property <[BindingEntry]> kb-bindings: [];
    in property <[string]> kb-sections: [];
    in-out property <int> kb-selected-section: 0;
    in-out property <string> kb-filter-text: "";
    in-out property <int> kb-edit-idx: -1;
    in property <string> kb-status-text: "";
    in property <bool> kb-has-changes: false;
    in-out property <bool> kb-capturing: false;
    in-out property <int> kb-capture-idx: -1;
    in property <string> kb-capture-combo: "";
    property <bool> kb-adding: false;
    in-out property <string> kb-new-desc: "";
    in-out property <string> kb-new-cmd: "";

    // Computed: true when wifi-status represents an error message.
    // Set from Rust alongside wifi-status via set_wifi_status_is_error().
    in property <bool> wifi-status-is-error: false;

    // ── Taskbar tab properties ──
    in-out property <int>  tb-ws-count: 4;
    in-out property <int>  tb-ws-position-index: 0;      // 0 = center, 1 = left
    in-out property <int>  tb-ws-spacing: 1;             // pixel gap between dots (1-10)
    in-out property <int>  tb-ws-style-index: 0;         // 0 = numbers, 1 = squares
    // Clock
    in-out property <int>  tb-clock-format-index: 0;    // 0=time, 1=dow, 2=date
    in-out property <bool> tb-clock-24h: false;          // true=24h, false=AM/PM
    in-out property <int>  tb-clock-date-fmt-index: 0;  // 0=M/D, 1=D/M, 2=ISO, 3=Mon D

    // ── Startup tab properties ──
    in property <[StartupEntry]> startup-items: [];
    in property <[AvailableAppEntry]> startup-available-apps: [];
    in-out property <bool> startup-show-add-dialog: false;
    in-out property <string> startup-filter-text: "";
    in property <string> startup-status-text: "";

    // ── Wi-Fi tab properties ──
    in property <[WifiEntry]> wifi-networks: [];
    in-out property <int>    wifi-selected-idx: -1;
    in-out property <string> wifi-password-input: "";
    in-out property <bool>   wifi-show-password: false;
    in property <bool>       wifi-scanning: false;
    in property <bool>       wifi-connecting: false;
    in property <string>     wifi-status: "";
    in property <string>     wifi-current-ssid: "";
    in property <image>      wifi-qr-image;
    in-out property <bool>   wifi-qr-visible: false;
    in-out property <string> wifi-qr-error: "";
    in-out property <string> wifi-uri-input: "";

    // ── Callbacks ──
    callback close();
    callback move-window(float, float);
    // Keyboard
    callback add-layout(int);
    callback remove-layout(int);
    callback preview-layout(int);
    callback preview-dropdown(int);
    callback filter-layouts(string);

    // Dictation
    callback filter-dictation-langs(string);
    callback select-dictation-lang(int);
    callback start-dictation-install();
    callback start-dictation-reconfigure();
    callback open-dictation-config();
    callback restart-dictation-service();
    callback cancel-dictation-install();

    // Display
    callback disp-select-monitor(int);
    callback disp-drag-finished(int, float, float);
    callback disp-change-resolution(int, int);
    callback disp-change-scale(int, float);
    callback disp-set-primary(int);
    callback disp-apply-changes();
    callback disp-revert-changes();
    callback disp-refresh-monitors();
    callback disp-identify-monitors();
    callback disp-set-window-guard(bool);

    // Power
    callback set-power-profile(int);
    callback set-idle-lock(int);
    callback set-idle-dpms(int);
    callback set-idle-suspend(int);
    callback set-idle-shutdown(int);

    // Keybindings
    callback kb-load();
    callback kb-filter(string, int);
    callback kb-edit-combo(int);
    callback kb-save-combo(int, string, string);
    callback kb-edit-args(int, string);
    callback kb-remove(int);
    callback kb-add(string, string);
    callback kb-save();
    callback kb-revert();
    callback kb-open-editor();
    callback kb-cancel-capture();

    // Taskbar
    callback tb-set-ws-count(int);
    callback tb-set-ws-position(int);
    callback tb-set-ws-spacing(int);
    callback tb-set-ws-style(int);
    callback tb-set-clock-format(int);     // 0=time, 1=dow, 2=date
    callback tb-set-clock-24h(bool);       // true=24h, false=AM/PM
    callback tb-set-clock-date-fmt(int);   // 0=M/D, 1=D/M, 2=ISO, 3=Mon D

    // Startup
    callback startup-load();                // refresh startup items list
    callback startup-toggle(int, bool);     // toggle item at index on/off
    callback startup-add(int);              // add available app at index
    callback startup-remove(int);           // remove startup item at index
    callback startup-filter-apps(string);   // filter available apps list

    // Wi-Fi
    callback wifi-list();                  // fast refresh (no active rescan)
    callback wifi-scan();                  // active rescan (background thread)
    callback wifi-connect(int, string, int); // (network_idx, password, security_idx)
    callback wifi-disconnect();
    callback wifi-forget(int);             // network_idx
    callback wifi-generate-qr(int);        // network_idx → renders QR into wifi-qr-image
    callback wifi-apply-uri(string);       // connect from a WIFI: URI string
    callback wifi-scan-screenshot();       // grim + zbarimg screen scan
    callback wifi-export-qr(int);          // save QR SVG to ~/Downloads/
    callback wifi-set-airplane(bool);       // true = airplane mode (radio off)

    // ── Wi-Fi radio state ──
    in-out property <bool> wifi-airplane-mode: false;
    in property <bool> wifi-no-hardware: false;

    // Search
    callback filter-search(string);

    // ── Keyboard shortcuts ──
    focus-scope := FocusScope {
        // Grab focus on launch so shortcuts work immediately
        init => { self.focus(); }
        key-pressed(e) => {
            // Key capture mode for keybinding editing
            if root.kb-capturing {
                if e.text == Key.Escape {
                    root.kb-capturing = false;
                    root.kb-capture-idx = -1;
                    root.kb-cancel-capture();
                    return accept;
                }
                // Build modifier+key combo display and send to backend
                // Skip pure modifier presses (they have no printable text beyond the mod key names)
                if e.text != Key.Control && e.text != Key.Alt && e.text != Key.Shift && e.text != Key.Meta {
                    // Build mods string for Hyprland format
                    root.kb-save-combo(
                        root.kb-capture-idx,
                        (e.modifiers.meta ? "SUPER " : "")
                            + (e.modifiers.control ? "CTRL " : "")
                            + (e.modifiers.alt ? "ALT " : "")
                            + (e.modifiers.shift ? "SHIFT " : ""),
                        e.text
                    );
                    root.kb-capturing = false;
                    root.kb-capture-idx = -1;
                    return accept;
                }
                return accept;
            }
            if e.text == Key.Escape {
                if root.dropdown-open {
                    root.dropdown-open = false;
                    return accept;
                }
                if root.dictation-lang-dropdown-open {
                    root.dictation-lang-dropdown-open = false;
                    return accept;
                }
                if root.show-help {
                    root.show-help = false;
                    return accept;
                }
                if root.dictation-configuring {
                    root.dictation-configuring = false;
                    return accept;
                }
                if root.kb-edit-idx >= 0 {
                    root.kb-edit-idx = -1;
                    root.kb-capture-idx = -1;
                    root.kb-capturing = false;
                    return accept;
                }
                if root.kb-adding {
                    root.kb-adding = false;
                    return accept;
                }
                if root.startup-show-add-dialog {
                    root.startup-show-add-dialog = false;
                    focus-scope.focus();
                    return accept;
                }
                root.close();
                return accept;
            }
            if e.modifiers.alt && (e.text == "a" || e.text == "A") && root.active-tab == 1 {
                if root.available-layouts.length > 0 && root.selected-dropdown-index >= 0 {
                    root.add-layout(root.selected-dropdown-index);
                }
                return accept;
            }
            if e.modifiers.alt && (e.text == "c" || e.text == "C") && root.active-tab == 1 {
                root.dropdown-open = !root.dropdown-open;
                root.search-text = "";
                root.highlighted-dropdown-index = 0;
                if root.dropdown-open {
                    search-input.focus();
                }
                return accept;
            }
            if e.modifiers.alt && (e.text == "d" || e.text == "D") && root.active-tab == 1 {
                if root.active-layouts.length > 1 {
                    root.remove-layout(1);
                }
                return accept;
            }
            // Display tab hotkeys
            if e.modifiers.alt && root.active-tab == 3 {
                if e.text == "i" {
                    root.disp-identify-monitors();
                    return accept;
                }
                if e.text == "r" {
                    root.disp-refresh-monitors();
                    return accept;
                }
                if e.text == "p" && root.disp-selected-index >= 0 {
                    root.disp-set-primary(root.disp-selected-index);
                    return accept;
                }
                if e.text == "a" && root.disp-has-changes {
                    root.disp-apply-changes();
                    return accept;
                }
                if e.text == "v" && root.disp-has-changes {
                    root.disp-revert-changes();
                    return accept;
                }
            }
            if e.text == "?" {
                root.show-help = !root.show-help;
                root.dropdown-open = false;
                return accept;
            }
            // Ctrl+F — focus search box
            if e.modifiers.control && (e.text == "f" || e.text == "F") {
                global-search-input.focus();
                return accept;
            }
            // Search results keyboard navigation
            if root.global-search-text != "" && root.search-results.length > 0 {
                if e.text == Key.DownArrow {
                    if root.search-selected-index < root.search-results.length - 1 {
                        root.search-selected-index += 1;
                    }
                    return accept;
                }
                if e.text == Key.UpArrow {
                    if root.search-selected-index > 0 {
                        root.search-selected-index -= 1;
                    }
                    return accept;
                }
                if e.text == Key.Return {
                    root.active-tab = root.search-results[root.search-selected-index].tab-index;
                    root.global-search-text = "";
                    root.search-selected-index = 0;
                    root.filter-search("");
                    return accept;
                }
            }
            if root.global-search-text != "" && e.text == Key.Escape {
                root.global-search-text = "";
                root.search-selected-index = 0;
                root.filter-search("");
                focus-scope.focus();
                return accept;
            }
            // Tab switching: 1-8
            if !root.dropdown-open && !root.dictation-lang-dropdown-open {
                if e.text == "1" { root.active-tab = 0; return accept; }
                if e.text == "2" { root.active-tab = 1; return accept; }
                if e.text == "3" { root.active-tab = 2; return accept; }
                if e.text == "4" { root.active-tab = 3; return accept; }
                if e.text == "5" { root.active-tab = 4; return accept; }
                if e.text == "6" { root.active-tab = 5; root.kb-load(); return accept; }
                if e.text == "7" { root.active-tab = 6; return accept; }
                if e.text == "8" { root.active-tab = 7; root.wifi-list(); return accept; }
                if e.text == "9" { root.active-tab = 8; root.startup-load(); return accept; }
            }
            reject
        }
    }

    // ── Layout ───────────────────────────────────────────────────────────────

    VerticalLayout {
        padding: 10px;
        spacing: 6px;

        // ── Header ──
        HorizontalLayout {
            height: 32px;
            spacing: 8px;

            // Search input (doubles as title bar)
            Rectangle {
                horizontal-stretch: 1;
                background: transparent;

                // "Settings" title, centered
                Text {
                    text: "Settings";
                    color: Theme.fg;
                    font-size: 14px;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                    width: 100%;
                    height: 100%;
                }

                // Drag area (full header, but search box sits on top to block it)
                drag-area := TouchArea {
                    moved => {
                        root.move-window(
                            (self.mouse-x - self.pressed-x) / 1px,
                            (self.mouse-y - self.pressed-y) / 1px,
                        );
                    }
                    mouse-cursor: move;
                }
            }

            // Inline search box (right edge of title bar)
            Rectangle {
                width: 160px;
                height: 24px;
                border-radius: 4px;
                background: Theme.bg_light;

                HorizontalLayout {
                    spacing: 4px;
                    padding-left: 6px;
                    padding-right: 6px;

                    VerticalLayout {
                        alignment: center;
                        Text {
                            text: "\u{1F50D}";
                            font-size: 10px;
                            color: Theme.fg_dim;
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        horizontal-stretch: 1;

                        Rectangle {
                            // Placeholder
                            Text {
                                visible: root.global-search-text == "";
                                text: "Search...";
                                font-size: 11px;
                                color: Theme.fg_dim;
                                vertical-alignment: center;
                            }

                            global-search-input := TextInput {
                                font-size: 11px;
                                color: Theme.fg;
                                text <=> root.global-search-text;
                                edited => {
                                    root.search-selected-index = 0;
                                    root.filter-search(self.text);
                                }
                                accepted => {
                                    if root.search-results.length > 0 {
                                        root.active-tab = root.search-results[root.search-selected-index].tab-index;
                                        self.text = "";
                                        root.global-search-text = "";
                                        root.search-selected-index = 0;
                                        root.filter-search("");
                                        focus-scope.focus();
                                    }
                                }
                            }
                        }
                    }
                }

                // Block drag on the search box
                TouchArea {
                    mouse-cursor: text;
                    clicked => {
                        global-search-input.focus();
                    }
                }
            }

            // Help button
            Rectangle {
                width: 26px;
                height: 26px;
                border-radius: 4px;
                background: help-area.has-hover ? Theme.accent : Theme.bg_light;

                Text {
                    width: 100%; height: 100%;
                    text: "?";
                    color: help-area.has-hover ? Theme.bg : Theme.fg;
                    font-size: 13px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                help-area := TouchArea {
                    clicked => {
                        root.show-help = !root.show-help;
                        root.dropdown-open = false;
                        focus-scope.focus();
                    }
                }
            }

            // Close button
            Rectangle {
                width: 26px;
                height: 26px;
                border-radius: 4px;
                background: close-area.has-hover ? Theme.danger : Theme.bg_light;

                Text {
                    width: 100%; height: 100%;
                    text: "\u{2715}";
                    color: close-area.has-hover ? Theme.bg : Theme.fg;
                    font-size: 12px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                close-area := TouchArea {
                    clicked => { root.close(); }
                }
            }
        }

        // Separator
        Rectangle { height: 1px; background: Theme.bg_lighter; }

        // ── Main content: sidebar + tab content ──
        HorizontalLayout {
            spacing: 0px;
            vertical-stretch: 1;

            // ── Left sidebar ──
            Rectangle {
                width: 140px;

                VerticalLayout {
                    padding: 4px;
                    spacing: 4px;
                    alignment: start;

                    TabButton {
                        label: "About";
                        icon: "\u{2139}";
                        active: root.active-tab == 0;
                        clicked => {
                            root.active-tab = 0;
                            root.dropdown-open = false;
                            focus-scope.focus();
                        }
                    }

                    TabButton {
                        label: "Keyboard";
                        icon: "\u{2328}";
                        active: root.active-tab == 1;
                        clicked => {
                            root.active-tab = 1;
                            root.dropdown-open = false;
                            focus-scope.focus();
                        }
                    }

                    TabButton {
                        label: "Dictation";
                        icon: "\u{1F399}";
                        active: root.active-tab == 2;
                        clicked => {
                            root.active-tab = 2;
                            root.dropdown-open = false;
                            focus-scope.focus();
                        }
                    }

                    TabButton {
                        label: "Display";
                        icon: "\u{1F5B5}";
                        active: root.active-tab == 3;
                        clicked => {
                            root.active-tab = 3;
                            root.dropdown-open = false;
                            focus-scope.focus();
                        }
                    }

                    TabButton {
                        label: "Power";
                        icon: "\u{26A1}";
                        active: root.active-tab == 4;
                        clicked => {
                            root.active-tab = 4;
                            root.dropdown-open = false;
                            focus-scope.focus();
                        }
                    }

                    TabButton {
                        label: "Keybindings";
                        icon: "\u{2318}";
                        active: root.active-tab == 5;
                        clicked => {
                            root.active-tab = 5;
                            root.dropdown-open = false;
                            root.kb-load();
                            focus-scope.focus();
                        }
                    }

                    TabButton {
                        label: "Taskbar";
                        icon: "\u{2261}";
                        active: root.active-tab == 6;
                        clicked => {
                            root.active-tab = 6;
                            root.dropdown-open = false;
                            focus-scope.focus();
                        }
                    }

                    TabButton {
                        label: "Wi-Fi";
                        icon: "\u{224B}";
                        active: root.active-tab == 7;
                        clicked => {
                            root.active-tab = 7;
                            root.dropdown-open = false;
                            root.wifi-list();
                            focus-scope.focus();
                        }
                    }

                    TabButton {
                        label: "Startup";
                        icon: "\u{1F680}";
                        active: root.active-tab == 8;
                        clicked => {
                            root.active-tab = 8;
                            root.dropdown-open = false;
                            root.startup-load();
                            focus-scope.focus();
                        }
                    }
                }
            }

            // Sidebar separator
            Rectangle { width: 1px; background: Theme.bg_lighter; }

            // ── Tab content wrapper ───────────────────────────────────────
            // A single container that always has the same preferred height,
            // so the Wayland compositor doesn't resize when switching tabs.
            Rectangle {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                clip: true;

            // ══════════════════════════════════════════════════════════════
            // KEYBOARD TAB
            // ══════════════════════════════════════════════════════════════

            if root.active-tab == 1: Rectangle {
                width: parent.width;
                height: parent.height;
                clip: true;

                tab1-flick := Flickable {
                    width: parent.width - 6px;
                    height: parent.height;
                    viewport-width: self.width;

                VerticalLayout {
                    padding-left: 10px;
                    spacing: 6px;

                // ── Add layout row ──
                HorizontalLayout {
                    height: 30px;
                    spacing: 8px;

                    Rectangle {
                        horizontal-stretch: 1;
                        height: 30px;
                        border-radius: 4px;
                        background: dropdown-touch.has-hover ? Theme.bg_lighter : Theme.bg_light;
                        border-width: (root.highlight-setting == "Keyboard Layout" || root.highlight-setting == "Add Layout" || root.highlight-setting == "Remove Layout" || root.highlight-setting == "XKB Layout" || root.highlight-setting == "Input Language") && root.highlight-blink-on ? 2px : 0px;
                        border-color: (root.highlight-setting == "Keyboard Layout" || root.highlight-setting == "Add Layout" || root.highlight-setting == "Remove Layout" || root.highlight-setting == "XKB Layout" || root.highlight-setting == "Input Language") && root.highlight-blink-on ? Theme.accent : transparent;
                        animate border-width { duration: 400ms; easing: ease-in-out; }
                        animate border-color { duration: 400ms; easing: ease-in-out; }

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 6px;

                            Text {
                                horizontal-stretch: 1;
                                text: root.available-layouts.length <= 0
                                    ? "No layouts found"
                                    : root.selected-dropdown-index >= 0
                                        ? root.available-layouts[root.selected-dropdown-index]
                                        : "Select a layout... (Alt+C)";
                                color: root.selected-dropdown-index >= 0 ? Theme.fg : Theme.fg_dim;
                                font-size: 12px;
                                vertical-alignment: center;
                                overflow: elide;
                            }

                            Text {
                                text: root.dropdown-open ? "\u{25B2}" : "\u{25BC}";
                                color: Theme.fg_dim;
                                font-size: 10px;
                                vertical-alignment: center;
                            }
                        }

                        dropdown-touch := TouchArea {
                            clicked => {
                                root.dropdown-open = !root.dropdown-open;
                                root.search-text = "";
                                root.highlighted-dropdown-index = 0;
                                if root.dropdown-open {
                                    search-input.focus();
                                }
                            }
                        }
                    }

                    if root.active-layouts.length >= 2: Text {
                        text: "Max 2 layouts";
                        color: Theme.fg_dim;
                        font-size: 11px;
                        vertical-alignment: center;
                    }

                    Rectangle {
                        visible: root.active-layouts.length < 2;
                        height: 30px;
                        min-width: 32px;
                        border-radius: 4px;
                        background: root.available-layouts.length <= 0 || root.selected-dropdown-index < 0
                            ? Theme.bg_lighter.transparentize(60%)
                            : add-touch.has-hover ? Theme.success : Theme.bg_light;

                        HorizontalLayout {
                            alignment: center;
                            padding-left: 10px;
                            padding-right: 10px;

                            Rectangle {
                                width: 9px;
                                height: parent.height;
                                Text {
                                    text: "A";
                                    color: add-touch.has-hover ? Theme.bg : Theme.fg;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    horizontal-alignment: center;
                                    width: parent.width;
                                    height: parent.height;
                                }
                                Rectangle {
                                    x: 1px;
                                    y: parent.height / 2 + 7px;
                                    width: 7px;
                                    height: 1px;
                                    background: add-touch.has-hover ? Theme.bg : Theme.fg;
                                }
                            }

                            Text {
                                text: "dd Layout";
                                color: add-touch.has-hover ? Theme.bg : Theme.fg;
                                font-size: 12px;
                                vertical-alignment: center;
                            }
                        }

                        add-touch := TouchArea {
                            clicked => {
                                if root.available-layouts.length > 0 && root.selected-dropdown-index >= 0 {
                                    root.add-layout(root.selected-dropdown-index);
                                }
                            }
                            mouse-cursor: root.available-layouts.length > 0 && root.selected-dropdown-index >= 0 ? pointer : default;
                        }
                    }
                }

                // ── Active layouts list ──
                if root.active-layouts.length > 0: VerticalLayout {
                    spacing: 3px;
                    padding-top: 2px;
                    padding-bottom: 2px;

                    for entry[idx] in root.active-layouts: Rectangle {
                        height: 30px;
                        border-radius: 4px;
                        background: layout-row-touch.has-hover ? Theme.bg_lighter : Theme.bg_light;

                        layout-row-touch := TouchArea {
                            clicked => { root.preview-layout(idx); }
                        }

                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 6px;
                            spacing: 6px;

                            Text {
                                horizontal-stretch: 1;
                                text: entry.description;
                                color: Theme.fg;
                                font-size: 12px;
                                vertical-alignment: center;
                            }

                            Text {
                                text: entry.code;
                                color: Theme.fg_dim;
                                font-size: 11px;
                                vertical-alignment: center;
                            }

                            Rectangle {
                                width: 24px;
                                height: 24px;
                                border-radius: 4px;
                                background: preview-touch.has-hover ? Theme.accent : transparent;

                                Text {
                                    width: 100%; height: 100%;
                                    text: "\u{2328}";
                                    color: preview-touch.has-hover ? Theme.bg : Theme.fg_dim;
                                    font-size: 14px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                preview-touch := TouchArea {
                                    clicked => { root.preview-layout(idx); }
                                }
                            }

                            Rectangle {
                                width: 24px;
                                height: 24px;
                                border-radius: 4px;
                                background: remove-touch.has-hover ? Theme.danger : transparent;
                                visible: root.active-layouts.length > 1 && entry.code != "us";

                                Text {
                                    width: 100%; height: 100%;
                                    text: "\u{2715}";
                                    color: remove-touch.has-hover ? Theme.bg : Theme.fg_dim;
                                    font-size: 11px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                remove-touch := TouchArea {
                                    clicked => { root.remove-layout(idx); }
                                }
                            }
                        }
                    }
                }

                Rectangle { height: 1px; background: Theme.bg_lighter; }

                HorizontalLayout {
                    height: 20px;
                    Text {
                        text: root.layout-name;
                        color: Theme.fg_dim;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }

                // ── Keyboard rows ──
                Rectangle {
                    border-radius: 6px;
                    border-width: root.highlight-setting == "Keyboard Preview" && root.highlight-blink-on ? 2px : 0px;
                    border-color: root.highlight-setting == "Keyboard Preview" && root.highlight-blink-on ? Theme.accent : transparent;
                    animate border-width { duration: 400ms; easing: ease-in-out; }
                    animate border-color { duration: 400ms; easing: ease-in-out; }

                VerticalLayout {
                    spacing: 3px;

                    HorizontalLayout {
                        spacing: 3px;
                        for key in root.row0: KeyCap {
                            base: key.base; english: key.english;
                            w: key.w; is-modifier: key.is-modifier;
                        }
                    }
                    HorizontalLayout {
                        spacing: 3px;
                        for key in root.row1: KeyCap {
                            base: key.base; english: key.english;
                            w: key.w; is-modifier: key.is-modifier;
                        }
                    }
                    HorizontalLayout {
                        spacing: 3px;
                        for key in root.row2: KeyCap {
                            base: key.base; english: key.english;
                            w: key.w; is-modifier: key.is-modifier;
                        }
                    }
                    HorizontalLayout {
                        spacing: 3px;
                        for key in root.row3: KeyCap {
                            base: key.base; english: key.english;
                            w: key.w; is-modifier: key.is-modifier;
                        }
                    }
                    HorizontalLayout {
                        spacing: 3px;
                        for key in root.row4: KeyCap {
                            base: key.base; english: key.english;
                            w: key.w; is-modifier: key.is-modifier;
                        }
                    }
                }
                }
                }
                }

                ScrollIndicator {
                    x: parent.width - 5px;
                    y: 0;
                    height: parent.height;
                    viewport-height: tab1-flick.viewport-height;
                    viewport-y: tab1-flick.viewport-y;
                    visible-height: tab1-flick.height;
                }
            }

            // ══════════════════════════════════════════════════════════════
            // DICTATION TAB
            // ══════════════════════════════════════════════════════════════

            if root.active-tab == 2: Rectangle {
                width: parent.width;
                height: parent.height;
                clip: true;

                tab2-flick := Flickable {
                    width: parent.width - 6px;
                    height: parent.height;
                    viewport-width: self.width;

                VerticalLayout {
                    padding-left: 10px;
                    padding-right: 4px;
                    spacing: 10px;

                // ── Installing view ──
                if root.dictation-installing: VerticalLayout {
                    spacing: 12px;

                    Rectangle { vertical-stretch: 1; }

                    Text {
                        text: root.dictation-install-error
                            ? "Setup Failed"
                            : root.dictation-progress >= 1.0
                                ? "Complete!" : "Setting Up Dictation";
                        color: root.dictation-install-error ? Theme.danger : Theme.fg;
                        font-size: 14px;
                        font-weight: 600;
                        horizontal-alignment: center;
                    }

                    if !root.dictation-install-error: HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 20px;

                        Rectangle {
                            height: 6px;
                            border-radius: 3px;
                            background: Theme.bg_light;

                            Rectangle {
                                y: 0;
                                width: parent.width * root.dictation-progress;
                                height: parent.height;
                                border-radius: 3px;
                                background: root.dictation-progress >= 1.0
                                    ? Theme.success : Theme.accent;
                                animate width { duration: 400ms; easing: ease-in-out; }
                            }
                        }
                    }

                    Text {
                        text: root.dictation-progress-text;
                        color: root.dictation-install-error ? Theme.danger : Theme.fg_dim;
                        font-size: 12px;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }

                    if !root.dictation-install-error && root.dictation-progress < 1.0: Text {
                        text: "Follow any prompts in the terminal window";
                        color: Theme.fg_dim;
                        font-size: 10px;
                        horizontal-alignment: center;
                    }

                    if root.dictation-progress < 1.0: HorizontalLayout {
                        alignment: center;
                        Rectangle {
                            width: 80px;
                            height: 28px;
                            border-radius: 4px;
                            background: cancel-install-touch.has-hover
                                ? Theme.bg_lighter : Theme.bg_light;

                            Text {
                                width: 100%; height: 100%;
                                text: root.dictation-install-error ? "Back" : "Cancel";
                                color: Theme.fg_dim;
                                font-size: 11px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            cancel-install-touch := TouchArea {
                                clicked => { root.cancel-dictation-install(); }
                                mouse-cursor: pointer;
                            }
                        }
                    }

                    Rectangle { vertical-stretch: 1; }
                }

                // ── Setup / Reconfigure view ──
                if (!root.dictation-installed || root.dictation-configuring) && !root.dictation-installing: VerticalLayout {
                    spacing: 12px;

                    Text {
                        text: root.dictation-installed ? "Reconfigure Dictation" : "Set Up Dictation";
                        color: Theme.fg;
                        font-size: 14px;
                        font-weight: 600;
                    }

                    if !root.dictation-installed: Text {
                        text: "Local AI speech-to-text using Whisper.\nFully offline -- no cloud services.";
                        color: Theme.fg_dim;
                        font-size: 12px;
                        wrap: word-wrap;
                    }

                    // Language picker
                    Rectangle {
                        border-radius: 6px;
                        background: Theme.bg_light;
                        border-width: (root.highlight-setting == "Language Model" || root.highlight-setting == "Dictation" || root.highlight-setting == "Speech to Text" || root.highlight-setting == "Microphone") && root.highlight-blink-on ? 2px : 0px;
                        border-color: (root.highlight-setting == "Language Model" || root.highlight-setting == "Dictation" || root.highlight-setting == "Speech to Text" || root.highlight-setting == "Microphone") && root.highlight-blink-on ? Theme.accent : transparent;
                        animate border-width { duration: 400ms; easing: ease-in-out; }
                        animate border-color { duration: 400ms; easing: ease-in-out; }

                        VerticalLayout {
                            padding: 10px;
                            spacing: 6px;

                            Text {
                                text: "Language";
                                color: Theme.fg_dim;
                                font-size: 11px;
                                font-weight: 600;
                            }

                            Rectangle {
                                height: 32px;
                                border-radius: 4px;
                                background: lang-pick-touch.has-hover ? Theme.bg_lighter : Theme.bg;

                                HorizontalLayout {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    spacing: 6px;

                                    Text {
                                        horizontal-stretch: 1;
                                        text: root.dictation-selected-lang-name;
                                        color: Theme.fg;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }

                                    Text {
                                        text: root.dictation-lang-dropdown-open ? "\u{25B2}" : "\u{25BC}";
                                        color: Theme.fg_dim;
                                        font-size: 10px;
                                        vertical-alignment: center;
                                    }
                                }

                                lang-pick-touch := TouchArea {
                                    clicked => {
                                        root.dictation-lang-dropdown-open = !root.dictation-lang-dropdown-open;
                                        root.dictation-lang-search = "";
                                        root.dictation-lang-highlighted-idx = 0;
                                        if root.dictation-lang-dropdown-open {
                                            dictation-lang-search-input.focus();
                                        }
                                    }
                                    mouse-cursor: pointer;
                                }
                            }

                            if root.dictation-show-also-english: HorizontalLayout {
                                spacing: 6px;
                                height: 24px;

                                VerticalLayout {
                                    alignment: center;
                                    width: 16px;
                                    Rectangle {
                                        width: 16px;
                                        height: 16px;
                                        border-radius: 3px;
                                        border-width: 1px;
                                        border-color: root.dictation-also-english ? Theme.accent : Theme.fg_dim;
                                        background: root.dictation-also-english ? Theme.accent : transparent;

                                        Text {
                                            visible: root.dictation-also-english;
                                            text: "\u{2713}";
                                            color: Theme.bg;
                                            font-size: 11px;
                                            width: 100%;
                                            height: 100%;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }

                                        TouchArea {
                                            clicked => {
                                                root.dictation-also-english = !root.dictation-also-english;
                                            }
                                        }
                                    }
                                }

                                Text {
                                    text: "Also detect English";
                                    color: Theme.fg_dim;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    // Model picker
                    Rectangle {
                        border-radius: 6px;
                        background: Theme.bg_light;
                        border-width: (root.highlight-setting == "Whisper" || root.highlight-setting == "Voice Input") && root.highlight-blink-on ? 2px : 0px;
                        border-color: (root.highlight-setting == "Whisper" || root.highlight-setting == "Voice Input") && root.highlight-blink-on ? Theme.accent : transparent;
                        animate border-width { duration: 400ms; easing: ease-in-out; }
                        animate border-color { duration: 400ms; easing: ease-in-out; }

                        VerticalLayout {
                            padding: 10px;
                            spacing: 4px;

                            Text {
                                text: "Model";
                                color: Theme.fg_dim;
                                font-size: 11px;
                                font-weight: 600;
                            }

                            for model[idx] in root.dictation-model-list: Rectangle {
                                property <bool> disabled: model.english-only && !root.dictation-selected-lang-is-english;
                                height: 32px;
                                border-radius: 4px;
                                background: self.disabled
                                    ? transparent
                                    : idx == root.dictation-selected-model-idx
                                        ? Theme.accent.transparentize(70%)
                                        : model-item-touch.has-hover ? Theme.bg_lighter : transparent;
                                opacity: self.disabled ? 0.4 : 1.0;

                                HorizontalLayout {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    spacing: 6px;

                                    VerticalLayout {
                                        alignment: center;
                                        width: 14px;
                                        Rectangle {
                                            width: 14px;
                                            height: 14px;
                                            border-radius: 7px;
                                            border-width: 1.5px;
                                            border-color: idx == root.dictation-selected-model-idx
                                                ? Theme.accent : Theme.fg_dim;
                                            background: transparent;

                                            Rectangle {
                                                visible: idx == root.dictation-selected-model-idx;
                                                x: 3px;
                                                y: 3px;
                                                width: 8px;
                                                height: 8px;
                                                border-radius: 4px;
                                                background: Theme.accent;
                                            }
                                        }
                                    }

                                    Text {
                                        text: model.label;
                                        color: Theme.fg;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                    }

                                    Text {
                                        text: model.size;
                                        color: Theme.fg_dim;
                                        font-size: 10px;
                                        vertical-alignment: center;
                                    }

                                    Text {
                                        horizontal-stretch: 1;
                                        text: model.note;
                                        color: Theme.fg_dim;
                                        font-size: 10px;
                                        vertical-alignment: center;
                                        horizontal-alignment: right;
                                        overflow: elide;
                                    }
                                }

                                model-item-touch := TouchArea {
                                    clicked => {
                                        if !parent.disabled {
                                            root.dictation-selected-model-idx = idx;
                                        }
                                    }
                                    mouse-cursor: parent.disabled ? default : pointer;
                                }
                            }
                        }
                    }

                    // Action buttons
                    HorizontalLayout {
                        spacing: 8px;

                        if root.dictation-configuring: Rectangle {
                            horizontal-stretch: 1;
                            height: 34px;
                            border-radius: 4px;
                            background: cancel-reconfig-touch.has-hover
                                ? Theme.bg_lighter : Theme.bg_light;

                            Text {
                                width: 100%; height: 100%;
                                text: "Cancel";
                                color: Theme.fg_dim;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            cancel-reconfig-touch := TouchArea {
                                clicked => { root.dictation-configuring = false; }
                                mouse-cursor: pointer;
                            }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                            height: 34px;
                            border-radius: 6px;
                            background: go-touch.has-hover
                                ? Theme.accent.darker(0.1) : Theme.accent;

                            Text {
                                width: 100%; height: 100%;
                                text: root.dictation-installed
                                    ? "Save & Download Model" : "Install Dictation";
                                color: Theme.bg;
                                font-size: 13px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            go-touch := TouchArea {
                                clicked => {
                                    if root.dictation-installed {
                                        root.start-dictation-reconfigure();
                                    } else {
                                        root.start-dictation-install();
                                    }
                                }
                                mouse-cursor: pointer;
                            }
                        }
                    }
                }

                // ── Installed status view ──
                if root.dictation-installed && !root.dictation-configuring && !root.dictation-installing: VerticalLayout {
                    spacing: 10px;

                    if root.dictation-config-missing: Rectangle {
                        border-radius: 6px;
                        background: Theme.warning.transparentize(85%);

                        VerticalLayout {
                            padding: 10px;
                            spacing: 6px;

                            Text {
                                text: "Configuration file missing";
                                color: Theme.warning;
                                font-size: 12px;
                                font-weight: 600;
                            }

                            Text {
                                text: "Click Reconfigure to set up language and model.";
                                color: Theme.fg_dim;
                                font-size: 11px;
                                wrap: word-wrap;
                            }
                        }
                    }

                    HorizontalLayout {
                        height: 28px;
                        spacing: 8px;

                        Text {
                            text: "Dictation";
                            color: Theme.fg;
                            font-size: 14px;
                            font-weight: 600;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                height: 18px;
                                width: installed-badge-text.preferred-width + 10px;
                                border-radius: 3px;
                                background: Theme.success.transparentize(80%);

                                installed-badge-text := Text {
                                    width: 100%; height: 100%;
                                    text: "Installed";
                                    color: Theme.success;
                                    font-size: 10px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                height: 22px;
                                min-width: 70px;
                                border-radius: 11px;
                                background: root.dictation-service-running
                                    ? Theme.success.transparentize(80%)
                                    : Theme.fg_dim.transparentize(80%);

                                HorizontalLayout {
                                    padding-left: 8px;
                                    padding-right: 8px;
                                    spacing: 4px;
                                    alignment: center;

                                    Rectangle {
                                        width: 6px;
                                        height: 6px;
                                        border-radius: 3px;
                                        background: root.dictation-service-running
                                            ? Theme.success : Theme.fg_dim;
                                    }

                                    Text {
                                        text: root.dictation-service-running
                                            ? "Running" : "Stopped";
                                        color: root.dictation-service-running
                                            ? Theme.success : Theme.fg_dim;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    // How to use
                    Rectangle {
                        border-radius: 6px;
                        background: Theme.accent.transparentize(90%);

                        HorizontalLayout {
                            padding: 10px;
                            spacing: 8px;

                            Text {
                                text: "Press";
                                color: Theme.fg_dim;
                                font-size: 12px;
                                vertical-alignment: center;
                            }

                            Rectangle {
                                height: 22px;
                                width: shortcut-text.preferred-width + 12px;
                                border-radius: 4px;
                                background: Theme.bg_lighter;

                                shortcut-text := Text {
                                    width: 100%; height: 100%;
                                    text: "Super + Ctrl + X";
                                    color: Theme.accent;
                                    font-size: 11px;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            Text {
                                text: "to start/stop dictation";
                                color: Theme.fg_dim;
                                font-size: 12px;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                        }
                    }

                    // Config info
                    if !root.dictation-config-missing: Rectangle {
                        border-radius: 6px;
                        background: Theme.bg_light;
                        border-width: (root.highlight-setting == "Dictation" || root.highlight-setting == "Speech to Text" || root.highlight-setting == "Whisper" || root.highlight-setting == "Voice Input" || root.highlight-setting == "Language Model" || root.highlight-setting == "Microphone") && root.highlight-blink-on ? 2px : 0px;
                        border-color: (root.highlight-setting == "Dictation" || root.highlight-setting == "Speech to Text" || root.highlight-setting == "Whisper" || root.highlight-setting == "Voice Input" || root.highlight-setting == "Language Model" || root.highlight-setting == "Microphone") && root.highlight-blink-on ? Theme.accent : transparent;
                        animate border-width { duration: 400ms; easing: ease-in-out; }
                        animate border-color { duration: 400ms; easing: ease-in-out; }

                        VerticalLayout {
                            padding: 12px;
                            spacing: 8px;

                            HorizontalLayout {
                                spacing: 8px;
                                Text { text: "Language"; color: Theme.fg_dim; font-size: 12px; vertical-alignment: center; width: 70px; }
                                Text { text: root.dictation-language; color: Theme.fg; font-size: 12px; vertical-alignment: center; }
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                Text { text: "Model"; color: Theme.fg_dim; font-size: 12px; vertical-alignment: center; width: 70px; }
                                Text { text: root.dictation-model; color: Theme.fg; font-size: 12px; vertical-alignment: center; }
                            }
                        }
                    }

                    // Service stopped hint
                    if !root.dictation-service-running && !root.dictation-config-missing: Rectangle {
                        border-radius: 6px;
                        background: Theme.warning.transparentize(90%);

                        HorizontalLayout {
                            padding: 8px;
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 6px;

                            Text {
                                text: "Service is stopped.";
                                color: Theme.warning;
                                font-size: 11px;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }

                            Rectangle {
                                width: start-hint-text.preferred-width + 16px;
                                height: 24px;
                                border-radius: 4px;
                                background: start-hint-touch.has-hover
                                    ? Theme.success : Theme.success.transparentize(70%);

                                start-hint-text := Text {
                                    width: 100%; height: 100%;
                                    text: "Start";
                                    color: start-hint-touch.has-hover ? Theme.bg : Theme.success;
                                    font-size: 11px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }

                                start-hint-touch := TouchArea {
                                    clicked => { root.restart-dictation-service(); }
                                    mouse-cursor: pointer;
                                }
                            }
                        }
                    }

                    // Action buttons
                    HorizontalLayout {
                        spacing: 8px;

                        Rectangle {
                            horizontal-stretch: 1;
                            height: 32px;
                            border-radius: 4px;
                            background: reconfig-touch.has-hover
                                ? Theme.accent : Theme.bg_light;

                            Text {
                                width: 100%; height: 100%;
                                text: "Reconfigure";
                                color: reconfig-touch.has-hover ? Theme.bg : Theme.fg;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            reconfig-touch := TouchArea {
                                clicked => { root.dictation-configuring = true; }
                                mouse-cursor: pointer;
                            }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                            height: 32px;
                            border-radius: 4px;
                            background: config-touch.has-hover
                                ? Theme.bg_lighter : Theme.bg_light;

                            Text {
                                width: 100%; height: 100%;
                                text: "Edit Config";
                                color: config-touch.has-hover ? Theme.fg : Theme.fg_dim;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            config-touch := TouchArea {
                                clicked => { root.open-dictation-config(); }
                                mouse-cursor: pointer;
                            }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                            height: 32px;
                            border-radius: 4px;
                            background: restart-touch.has-hover
                                ? (root.dictation-service-running
                                    ? Theme.warning : Theme.success)
                                : Theme.bg_light;

                            Text {
                                width: 100%; height: 100%;
                                text: root.dictation-service-running
                                    ? "Restart" : "Start";
                                color: restart-touch.has-hover ? Theme.bg : Theme.fg_dim;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            restart-touch := TouchArea {
                                clicked => { root.restart-dictation-service(); }
                                mouse-cursor: pointer;
                            }
                        }
                    }

                    Rectangle { vertical-stretch: 1; }
                }
                }
                }

                ScrollIndicator {
                    x: parent.width - 5px;
                    y: 0;
                    height: parent.height;
                    viewport-height: tab2-flick.viewport-height;
                    viewport-y: tab2-flick.viewport-y;
                    visible-height: tab2-flick.height;
                }
            }

            // ══════════════════════════════════════════════════════════════
            // DISPLAY TAB
            // ══════════════════════════════════════════════════════════════

            if root.active-tab == 3: Rectangle {
                width: parent.width;
                height: parent.height;
                clip: true;

                tab3-flick := Flickable {
                    width: parent.width - 6px;
                    height: parent.height;
                    viewport-width: self.width;

                VerticalLayout {
                    padding-left: 10px;
                    padding-right: 4px;
                    spacing: 10px;

                // Display header with buttons
                HorizontalLayout {
                    height: 28px;
                    spacing: 8px;

                    Text {
                        text: "Display";
                        color: Theme.fg;
                        font-size: 14px;
                        font-weight: 600;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }

                    // Identify button
                    Rectangle {
                        height: 26px;
                        min-width: disp-identify-layout.preferred-width + 20px;
                        border-radius: 4px;
                        background: disp-identify-touch.has-hover ? Theme.accent : Theme.bg_light;

                        disp-identify-layout := HorizontalLayout {
                            alignment: center;
                            padding-left: 10px;
                            padding-right: 10px;

                            Rectangle {
                                width: 6px;
                                height: parent.height;
                                Text {
                                    text: "I";
                                    color: disp-identify-touch.has-hover ? Theme.bg : Theme.fg;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    horizontal-alignment: center;
                                    width: parent.width;
                                    height: parent.height;
                                }
                                Rectangle {
                                    x: 0px;
                                    y: parent.height / 2 + 7px;
                                    width: parent.width;
                                    height: 1px;
                                    background: disp-identify-touch.has-hover ? Theme.bg : Theme.fg;
                                }
                            }
                            Text {
                                text: "dentify";
                                color: disp-identify-touch.has-hover ? Theme.bg : Theme.fg;
                                font-size: 12px;
                                vertical-alignment: center;
                            }
                        }

                        disp-identify-touch := TouchArea {
                            clicked => { root.disp-identify-monitors(); }
                            mouse-cursor: pointer;
                        }
                    }

                    // Refresh button
                    Rectangle {
                        height: 26px;
                        min-width: disp-refresh-layout.preferred-width + 20px;
                        border-radius: 4px;
                        background: disp-refresh-touch.has-hover ? Theme.accent : Theme.bg_light;

                        disp-refresh-layout := HorizontalLayout {
                            alignment: center;
                            padding-left: 10px;
                            padding-right: 10px;

                            Rectangle {
                                width: 9px;
                                height: parent.height;
                                Text {
                                    text: "R";
                                    color: disp-refresh-touch.has-hover ? Theme.bg : Theme.fg;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    horizontal-alignment: center;
                                    width: parent.width;
                                    height: parent.height;
                                }
                                Rectangle {
                                    x: 1px;
                                    y: parent.height / 2 + 7px;
                                    width: 7px;
                                    height: 1px;
                                    background: disp-refresh-touch.has-hover ? Theme.bg : Theme.fg;
                                }
                            }
                            Text {
                                text: "efresh";
                                color: disp-refresh-touch.has-hover ? Theme.bg : Theme.fg;
                                font-size: 12px;
                                vertical-alignment: center;
                            }
                        }

                        disp-refresh-touch := TouchArea {
                            clicked => { root.disp-refresh-monitors(); }
                            mouse-cursor: pointer;
                        }
                    }
                }

                // ── Monitor Canvas card ──
                Rectangle {
                    background: Theme.bg.darker(0.3);
                    border-radius: 6px;
                    border-width: (root.highlight-setting == "Display" || root.highlight-setting == "Monitor" || root.highlight-setting == "Screen Layout") && root.highlight-blink-on ? 2px : 1px;
                    border-color: (root.highlight-setting == "Display" || root.highlight-setting == "Monitor" || root.highlight-setting == "Screen Layout") && root.highlight-blink-on ? Theme.accent : Theme.bg_lighter;
                    animate border-width { duration: 400ms; easing: ease-in-out; }
                    animate border-color { duration: 400ms; easing: ease-in-out; }
                    height: 200px;

                    if disp-monitors.length == 0: Text {
                        text: "No monitors detected";
                        color: Theme.fg_dim;
                        font-size: 14px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    for mon[i] in disp-monitors: MonitorRect {
                        width: mon.canvas-w * 1px;
                        height: mon.canvas-h * 1px;
                        base-x: mon.canvas-x;
                        base-y: mon.canvas-y;
                        label: mon.name;
                        sublabel: "\{mon.width}x\{mon.height}";
                        selected: i == disp-selected-index;
                        is-primary: mon.is-primary;

                        clicked => {
                            root.disp-selected-index = i;
                            root.disp-select-monitor(i);
                        }

                        drag-finished(cx, cy) => {
                            root.disp-selected-index = i;
                            root.disp-drag-finished(i, cx, cy);
                        }
                    }
                }

                // ── Monitor settings cards (shown when a monitor is selected) ──
                if disp-selected-index >= 0 && disp-selected-index < disp-monitors.length: VerticalLayout {
                    spacing: 10px;

                    // Monitor name header
                    Text {
                        text: "Monitor: " + disp-monitors[root.disp-selected-index].name + "  \u{2014}  " + disp-monitors[root.disp-selected-index].description;
                        color: Theme.fg_dim;
                        font-size: 11px;
                        overflow: elide;
                    }

                    // ── Resolution & Refresh Rate card ──
                    Rectangle {
                        border-radius: 6px;
                        background: Theme.bg_light;
                        border-width: (root.highlight-setting == "Resolution" || root.highlight-setting == "Refresh Rate") && root.highlight-blink-on ? 2px : 0px;
                        border-color: (root.highlight-setting == "Resolution" || root.highlight-setting == "Refresh Rate") && root.highlight-blink-on ? Theme.accent : transparent;
                        animate border-width { duration: 400ms; easing: ease-in-out; }
                        animate border-color { duration: 400ms; easing: ease-in-out; }

                        VerticalLayout {
                            padding: 12px;
                            spacing: 8px;

                            Text {
                                text: "Resolution & Refresh Rate";
                                color: Theme.fg_dim;
                                font-size: 11px;
                                font-weight: 600;
                            }

                            ResDropdown {
                                model: root.disp-selected-modes;
                                current-index: root.disp-selected-mode-index;
                                selected(idx) => {
                                    root.disp-change-resolution(root.disp-selected-index, idx);
                                }
                            }
                        }
                    }

                    // ── Scale card ──
                    Rectangle {
                        border-radius: 6px;
                        background: Theme.bg_light;
                        border-width: root.highlight-setting == "Scale" && root.highlight-blink-on ? 2px : 0px;
                        border-color: root.highlight-setting == "Scale" && root.highlight-blink-on ? Theme.accent : transparent;
                        animate border-width { duration: 400ms; easing: ease-in-out; }
                        animate border-color { duration: 400ms; easing: ease-in-out; }

                        VerticalLayout {
                            padding: 12px;
                            spacing: 8px;

                            Text {
                                text: "Scale: " + round(root.disp-selected-scale * 100) / 100;
                                color: Theme.fg_dim;
                                font-size: 11px;
                                font-weight: 600;
                            }

                            ThemeSlider {
                                value: root.disp-selected-scale;
                                minimum: 0.5;
                                maximum: 3.0;
                                changed(v) => {
                                    root.disp-change-scale(root.disp-selected-index, v);
                                }
                            }
                        }
                    }

                    // ── Primary Monitor card ──
                    Rectangle {
                        border-radius: 6px;
                        background: Theme.bg_light;
                        border-width: root.highlight-setting == "Primary Monitor" && root.highlight-blink-on ? 2px : 0px;
                        border-color: root.highlight-setting == "Primary Monitor" && root.highlight-blink-on ? Theme.accent : transparent;
                        animate border-width { duration: 400ms; easing: ease-in-out; }
                        animate border-color { duration: 400ms; easing: ease-in-out; }

                        HorizontalLayout {
                            padding: 12px;
                            spacing: 10px;

                            VerticalLayout {
                                horizontal-stretch: 1;
                                spacing: 2px;
                                alignment: center;

                                Text {
                                    text: "Primary Monitor";
                                    color: Theme.fg_dim;
                                    font-size: 11px;
                                    font-weight: 600;
                                }

                                Text {
                                    text: disp-monitors[root.disp-selected-index].is-primary
                                        ? "This monitor is primary"
                                        : "Set this monitor as the main display";
                                    color: Theme.fg_dim;
                                    font-size: 10px;
                                }
                            }

                            VerticalLayout {
                                alignment: center;

                                Rectangle {
                                    height: 28px;
                                    min-width: disp-primary-layout.preferred-width + 20px;
                                    border-radius: 4px;
                                    background: disp-monitors[root.disp-selected-index].is-primary
                                        ? Theme.bg_light.darker(0.2)
                                        : disp-primary-touch.has-hover ? Theme.accent : Theme.bg_lighter;

                                    disp-primary-layout := HorizontalLayout {
                                        alignment: center;
                                        padding-left: 10px;
                                        padding-right: 10px;

                                        if !disp-monitors[root.disp-selected-index].is-primary: Text {
                                            text: "Set ";
                                            color: disp-primary-touch.has-hover ? Theme.bg : Theme.fg;
                                            font-size: 12px;
                                            vertical-alignment: center;
                                        }

                                        Rectangle {
                                            width: 10px;
                                            height: parent.height;
                                            Text {
                                                text: "P";
                                                color: disp-monitors[root.disp-selected-index].is-primary
                                                    ? Theme.fg_dim.darker(0.3)
                                                    : disp-primary-touch.has-hover ? Theme.bg : Theme.fg;
                                                font-size: 12px;
                                                vertical-alignment: center;
                                                horizontal-alignment: center;
                                                width: parent.width;
                                                height: parent.height;
                                            }
                                            Rectangle {
                                                x: 1px;
                                                y: parent.height / 2 + 7px;
                                                width: 8px;
                                                height: 1px;
                                                background: disp-monitors[root.disp-selected-index].is-primary
                                                    ? Theme.fg_dim.darker(0.3)
                                                    : disp-primary-touch.has-hover ? Theme.bg : Theme.fg;
                                            }
                                        }

                                        Text {
                                            text: "rimary";
                                            color: disp-monitors[root.disp-selected-index].is-primary
                                                ? Theme.fg_dim.darker(0.3)
                                                : disp-primary-touch.has-hover ? Theme.bg : Theme.fg;
                                            font-size: 12px;
                                            vertical-alignment: center;
                                        }
                                    }

                                    disp-primary-touch := TouchArea {
                                        enabled: !disp-monitors[root.disp-selected-index].is-primary;
                                        mouse-cursor: disp-monitors[root.disp-selected-index].is-primary ? default : pointer;
                                        clicked => {
                                            root.disp-set-primary(root.disp-selected-index);
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // ── Keep windows on-screen card ──
                    Rectangle {
                        border-radius: 6px;
                        background: Theme.bg_light;

                        HorizontalLayout {
                            padding: 12px;
                            spacing: 10px;

                            VerticalLayout {
                                horizontal-stretch: 1;
                                spacing: 2px;
                                alignment: center;

                                Text {
                                    text: "Keep windows on-screen";
                                    color: Theme.fg_dim;
                                    font-size: 11px;
                                    font-weight: 600;
                                }

                                Text {
                                    text: "Snap floating windows back if they end up outside the visible area";
                                    color: Theme.fg_dim;
                                    font-size: 10px;
                                    wrap: word-wrap;
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                width: 42px;

                                Rectangle {
                                    width: 38px;
                                    height: 20px;
                                    border-radius: 10px;
                                    background: root.disp-window-guard
                                        ? Theme.accent
                                        : Theme.bg_lighter;

                                    Rectangle {
                                        x: root.disp-window-guard ? parent.width - self.width - 2px : 2px;
                                        y: 2px;
                                        width: 16px;
                                        height: 16px;
                                        border-radius: 8px;
                                        background: root.disp-window-guard
                                            ? Theme.bg
                                            : Theme.fg_dim;

                                        animate x { duration: 150ms; easing: ease-in-out; }
                                    }

                                    TouchArea {
                                        clicked => {
                                            root.disp-window-guard = !root.disp-window-guard;
                                            root.disp-set-window-guard(root.disp-window-guard);
                                        }
                                        mouse-cursor: pointer;
                                    }
                                }
                            }
                        }
                    }
                }

                // Footer: status + action buttons
                HorizontalLayout {
                    height: 28px;
                    spacing: 8px;

                    Text {
                        text: root.disp-status-text;
                        color: Theme.fg_dim;
                        font-size: 10px;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }

                    // Revert
                    Rectangle {
                        height: 26px;
                        min-width: disp-revert-layout.preferred-width + 20px;
                        border-radius: 4px;
                        background: !root.disp-has-changes
                            ? Theme.bg_light.darker(0.2)
                            : disp-revert-touch.has-hover ? Theme.warning : Theme.bg_light;

                        disp-revert-layout := HorizontalLayout {
                            alignment: center;
                            padding-left: 10px;
                            padding-right: 10px;

                            Text {
                                text: "Re";
                                color: !root.disp-has-changes ? Theme.fg_dim.darker(0.3)
                                    : disp-revert-touch.has-hover ? Theme.bg : Theme.fg;
                                font-size: 12px;
                                vertical-alignment: center;
                            }

                            Rectangle {
                                width: 8px;
                                height: parent.height;
                                Text {
                                    text: "v";
                                    color: !root.disp-has-changes ? Theme.fg_dim.darker(0.3)
                                        : disp-revert-touch.has-hover ? Theme.bg : Theme.fg;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    horizontal-alignment: center;
                                    width: parent.width;
                                    height: parent.height;
                                }
                                Rectangle {
                                    x: 0px;
                                    y: parent.height / 2 + 7px;
                                    width: parent.width;
                                    height: 1px;
                                    background: !root.disp-has-changes ? Theme.fg_dim.darker(0.3)
                                        : disp-revert-touch.has-hover ? Theme.bg : Theme.fg;
                                }
                            }

                            Text {
                                text: "ert";
                                color: !root.disp-has-changes ? Theme.fg_dim.darker(0.3)
                                    : disp-revert-touch.has-hover ? Theme.bg : Theme.fg;
                                font-size: 12px;
                                vertical-alignment: center;
                            }
                        }

                        disp-revert-touch := TouchArea {
                            enabled: root.disp-has-changes;
                            mouse-cursor: root.disp-has-changes ? pointer : default;
                            clicked => { root.disp-revert-changes(); }
                        }
                    }

                    // Apply
                    Rectangle {
                        height: 26px;
                        min-width: disp-apply-layout.preferred-width + 20px;
                        border-radius: 4px;
                        background: !root.disp-has-changes
                            ? Theme.bg_light.darker(0.2)
                            : disp-apply-touch.has-hover ? Theme.success : Theme.bg_light;

                        disp-apply-layout := HorizontalLayout {
                            alignment: center;
                            padding-left: 10px;
                            padding-right: 10px;

                            Rectangle {
                                width: 9px;
                                height: parent.height;
                                Text {
                                    text: "A";
                                    color: !root.disp-has-changes ? Theme.fg_dim.darker(0.3)
                                        : disp-apply-touch.has-hover ? Theme.bg : Theme.fg;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    horizontal-alignment: center;
                                    width: parent.width;
                                    height: parent.height;
                                }
                                Rectangle {
                                    x: 1px;
                                    y: parent.height / 2 + 7px;
                                    width: 7px;
                                    height: 1px;
                                    background: !root.disp-has-changes ? Theme.fg_dim.darker(0.3)
                                        : disp-apply-touch.has-hover ? Theme.bg : Theme.fg;
                                }
                            }

                            Text {
                                text: "pply";
                                color: !root.disp-has-changes ? Theme.fg_dim.darker(0.3)
                                    : disp-apply-touch.has-hover ? Theme.bg : Theme.fg;
                                font-size: 12px;
                                vertical-alignment: center;
                            }
                        }

                        disp-apply-touch := TouchArea {
                            enabled: root.disp-has-changes;
                            mouse-cursor: root.disp-has-changes ? pointer : default;
                            clicked => { root.disp-apply-changes(); }
                        }
                    }
                }
                }
                }

                ScrollIndicator {
                    x: parent.width - 5px;
                    y: 0;
                    height: parent.height;
                    viewport-height: tab3-flick.viewport-height;
                    viewport-y: tab3-flick.viewport-y;
                    visible-height: tab3-flick.height;
                }
            }

            // ══════════════════════════════════════════════════════════════
            // POWER TAB
            // ══════════════════════════════════════════════════════════════

            if root.active-tab == 4: Rectangle {
                width: parent.width;
                height: parent.height;
                clip: true;

                tab4-flick := Flickable {
                    width: parent.width - 6px;
                    height: parent.height;
                    viewport-width: self.width;

                VerticalLayout {
                    padding-left: 10px;
                    padding-right: 4px;
                    spacing: 12px;

                Text {
                    text: "Power";
                    color: Theme.fg;
                    font-size: 14px;
                    font-weight: 600;
                }

                // ── Power Profile card ──
                if root.power-profiles-available: Rectangle {
                    border-radius: 6px;
                    background: Theme.bg_light;
                    border-width: root.highlight-setting == "Power Profile" && root.highlight-blink-on ? 2px : 0px;
                    border-color: root.highlight-setting == "Power Profile" && root.highlight-blink-on ? Theme.accent : transparent;
                    animate border-width { duration: 400ms; easing: ease-in-out; }
                    animate border-color { duration: 400ms; easing: ease-in-out; }

                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;

                        Text {
                            text: "Power Profile";
                            color: Theme.fg_dim;
                            font-size: 11px;
                            font-weight: 600;
                        }

                        // Power saver
                        Rectangle {
                            height: 40px;
                            border-radius: 4px;
                            background: root.power-profile-index == 0
                                ? Theme.accent.transparentize(70%)
                                : power-saver-touch.has-hover ? Theme.bg_lighter : transparent;

                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 10px;

                                VerticalLayout {
                                    alignment: center;
                                    width: 14px;
                                    Rectangle {
                                        width: 14px; height: 14px;
                                        border-radius: 7px;
                                        border-width: 1.5px;
                                        border-color: root.power-profile-index == 0 ? Theme.accent : Theme.fg_dim;
                                        background: transparent;
                                        Rectangle {
                                            visible: root.power-profile-index == 0;
                                            x: 3px; y: 3px; width: 8px; height: 8px;
                                            border-radius: 4px;
                                            background: Theme.accent;
                                        }
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 2px;
                                    Text { text: "Power Saver"; color: Theme.fg; font-size: 12px; }
                                    Text { text: "Maximize battery life"; color: Theme.fg_dim; font-size: 10px; }
                                }
                            }

                            power-saver-touch := TouchArea {
                                clicked => {
                                    root.power-profile-index = 0;
                                    root.set-power-profile(0);
                                }
                                mouse-cursor: pointer;
                            }
                        }

                        // Balanced
                        Rectangle {
                            height: 40px;
                            border-radius: 4px;
                            background: root.power-profile-index == 1
                                ? Theme.accent.transparentize(70%)
                                : power-balanced-touch.has-hover ? Theme.bg_lighter : transparent;

                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 10px;

                                VerticalLayout {
                                    alignment: center;
                                    width: 14px;
                                    Rectangle {
                                        width: 14px; height: 14px;
                                        border-radius: 7px;
                                        border-width: 1.5px;
                                        border-color: root.power-profile-index == 1 ? Theme.accent : Theme.fg_dim;
                                        background: transparent;
                                        Rectangle {
                                            visible: root.power-profile-index == 1;
                                            x: 3px; y: 3px; width: 8px; height: 8px;
                                            border-radius: 4px;
                                            background: Theme.accent;
                                        }
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 2px;
                                    Text { text: "Balanced"; color: Theme.fg; font-size: 12px; }
                                    Text { text: "Default performance and battery"; color: Theme.fg_dim; font-size: 10px; }
                                }
                            }

                            power-balanced-touch := TouchArea {
                                clicked => {
                                    root.power-profile-index = 1;
                                    root.set-power-profile(1);
                                }
                                mouse-cursor: pointer;
                            }
                        }

                        // Performance
                        Rectangle {
                            height: 40px;
                            border-radius: 4px;
                            background: root.power-profile-index == 2
                                ? Theme.accent.transparentize(70%)
                                : power-perf-touch.has-hover ? Theme.bg_lighter : transparent;

                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 10px;

                                VerticalLayout {
                                    alignment: center;
                                    width: 14px;
                                    Rectangle {
                                        width: 14px; height: 14px;
                                        border-radius: 7px;
                                        border-width: 1.5px;
                                        border-color: root.power-profile-index == 2 ? Theme.accent : Theme.fg_dim;
                                        background: transparent;
                                        Rectangle {
                                            visible: root.power-profile-index == 2;
                                            x: 3px; y: 3px; width: 8px; height: 8px;
                                            border-radius: 4px;
                                            background: Theme.accent;
                                        }
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 2px;
                                    Text { text: "Performance"; color: Theme.fg; font-size: 12px; }
                                    Text { text: "Maximum performance, higher power use"; color: Theme.fg_dim; font-size: 10px; }
                                }
                            }

                            power-perf-touch := TouchArea {
                                clicked => {
                                    root.power-profile-index = 2;
                                    root.set-power-profile(2);
                                }
                                mouse-cursor: pointer;
                            }
                        }
                    }
                }

                // ── Lock Screen Timeout card ──
                Rectangle {
                    border-radius: 6px;
                    background: Theme.bg_light;
                    border-width: root.highlight-setting == "Lock Screen Timeout" && root.highlight-blink-on ? 2px : 0px;
                    border-color: root.highlight-setting == "Lock Screen Timeout" && root.highlight-blink-on ? Theme.accent : transparent;
                    animate border-width { duration: 400ms; easing: ease-in-out; }
                    animate border-color { duration: 400ms; easing: ease-in-out; }

                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;

                        Text {
                            text: "Lock screen after";
                            color: Theme.fg_dim;
                            font-size: 11px;
                            font-weight: 600;
                        }

                        HorizontalLayout {
                            spacing: 4px;

                            for preset[idx] in ["1 min", "5 min", "10 min", "30 min", "Never"]: Rectangle {
                                height: 28px;
                                min-width: 50px;
                                horizontal-stretch: 0;
                                border-radius: 4px;
                                background: root.idle-lock-index == idx
                                    ? Theme.accent
                                    : lock-chip-touch.has-hover ? Theme.bg_lighter : Theme.bg;

                                HorizontalLayout {
                                    alignment: center;
                                    padding-left: 8px;
                                    padding-right: 8px;

                                    Text {
                                        text: preset;
                                        color: root.idle-lock-index == idx ? Theme.bg : Theme.fg;
                                        font-size: 10px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                lock-chip-touch := TouchArea {
                                    clicked => {
                                        root.idle-lock-index = idx;
                                        root.set-idle-lock(idx);
                                    }
                                    mouse-cursor: pointer;
                                }
                            }

                            // Custom dropdown
                            Rectangle {
                                height: 28px;
                                min-width: 56px;
                                horizontal-stretch: 0;
                                border-radius: 4px;
                                background: root.idle-lock-index >= 5
                                    ? Theme.accent
                                    : lock-custom-touch.has-hover ? Theme.bg_lighter : Theme.bg;

                                HorizontalLayout {
                                    alignment: center;
                                    padding-left: 8px;
                                    padding-right: 8px;

                                    Text {
                                        text: root.idle-lock-index == 5 ? "1h"
                                            : root.idle-lock-index == 6 ? "2h"
                                            : root.idle-lock-index == 7 ? "3h"
                                            : root.idle-lock-index == 8 ? "5h"
                                            : root.idle-lock-index == 9 ? "8h"
                                            : "Custom";
                                        color: root.idle-lock-index >= 5 ? Theme.bg : Theme.fg;
                                        font-size: 10px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                lock-custom-touch := TouchArea {
                                    clicked => {
                                        root.idle-lock-index = root.idle-lock-index >= 5 ?
                                            (root.idle-lock-index >= 9 ? 5 : root.idle-lock-index + 1) : 5;
                                        root.set-idle-lock(root.idle-lock-index);
                                    }
                                    mouse-cursor: pointer;
                                }
                            }
                        }
                    }
                }

                // ── Screen Off Timeout card ──
                Rectangle {
                    border-radius: 6px;
                    background: Theme.bg_light;
                    border-width: root.highlight-setting == "Screen Off Timeout" && root.highlight-blink-on ? 2px : 0px;
                    border-color: root.highlight-setting == "Screen Off Timeout" && root.highlight-blink-on ? Theme.accent : transparent;
                    animate border-width { duration: 400ms; easing: ease-in-out; }
                    animate border-color { duration: 400ms; easing: ease-in-out; }
                    private property <string> _hl: root.highlight-setting;
                    init => { if _hl == "Screen Off Timeout" { tab4-flick.viewport-y = -max(0px, self.y - 20px); } }
                    changed _hl => { if _hl == "Screen Off Timeout" { tab4-flick.viewport-y = -max(0px, self.y - 20px); } }

                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;

                        Text {
                            text: "Turn off screen after";
                            color: Theme.fg_dim;
                            font-size: 11px;
                            font-weight: 600;
                        }

                        HorizontalLayout {
                            spacing: 4px;

                            for preset[idx] in ["1 min", "5 min", "10 min", "30 min", "Never"]: Rectangle {
                                height: 28px;
                                min-width: 50px;
                                horizontal-stretch: 0;
                                border-radius: 4px;
                                background: root.idle-dpms-index == idx
                                    ? Theme.accent
                                    : dpms-chip-touch.has-hover ? Theme.bg_lighter : Theme.bg;

                                HorizontalLayout {
                                    alignment: center;
                                    padding-left: 8px;
                                    padding-right: 8px;

                                    Text {
                                        text: preset;
                                        color: root.idle-dpms-index == idx ? Theme.bg : Theme.fg;
                                        font-size: 10px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                dpms-chip-touch := TouchArea {
                                    clicked => {
                                        root.idle-dpms-index = idx;
                                        root.set-idle-dpms(idx);
                                    }
                                    mouse-cursor: pointer;
                                }
                            }

                            // Custom dropdown
                            Rectangle {
                                height: 28px;
                                min-width: 56px;
                                horizontal-stretch: 0;
                                border-radius: 4px;
                                background: root.idle-dpms-index >= 5
                                    ? Theme.accent
                                    : dpms-custom-touch.has-hover ? Theme.bg_lighter : Theme.bg;

                                HorizontalLayout {
                                    alignment: center;
                                    padding-left: 8px;
                                    padding-right: 8px;

                                    Text {
                                        text: root.idle-dpms-index == 5 ? "1h"
                                            : root.idle-dpms-index == 6 ? "2h"
                                            : root.idle-dpms-index == 7 ? "3h"
                                            : root.idle-dpms-index == 8 ? "5h"
                                            : root.idle-dpms-index == 9 ? "8h"
                                            : "Custom";
                                        color: root.idle-dpms-index >= 5 ? Theme.bg : Theme.fg;
                                        font-size: 10px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                dpms-custom-touch := TouchArea {
                                    clicked => {
                                        root.idle-dpms-index = root.idle-dpms-index >= 5 ?
                                            (root.idle-dpms-index >= 9 ? 5 : root.idle-dpms-index + 1) : 5;
                                        root.set-idle-dpms(root.idle-dpms-index);
                                    }
                                    mouse-cursor: pointer;
                                }
                            }
                        }
                    }
                }

                // ── Suspend Timeout card ──
                Rectangle {
                    border-radius: 6px;
                    background: Theme.bg_light;
                    border-width: root.highlight-setting == "Suspend Timeout" && root.highlight-blink-on ? 2px : 0px;
                    border-color: root.highlight-setting == "Suspend Timeout" && root.highlight-blink-on ? Theme.accent : transparent;
                    animate border-width { duration: 400ms; easing: ease-in-out; }
                    animate border-color { duration: 400ms; easing: ease-in-out; }
                    private property <string> _hl: root.highlight-setting;
                    init => { if _hl == "Suspend Timeout" { tab4-flick.viewport-y = -max(0px, self.y - 20px); } }
                    changed _hl => { if _hl == "Suspend Timeout" { tab4-flick.viewport-y = -max(0px, self.y - 20px); } }

                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;

                        Text {
                            text: "Suspend after";
                            color: Theme.fg_dim;
                            font-size: 11px;
                            font-weight: 600;
                        }

                        HorizontalLayout {
                            spacing: 4px;

                            for preset[idx] in ["1 min", "5 min", "10 min", "30 min", "Never"]: Rectangle {
                                height: 28px;
                                min-width: 50px;
                                horizontal-stretch: 0;
                                border-radius: 4px;
                                background: root.idle-suspend-index == idx
                                    ? Theme.accent
                                    : susp-chip-touch.has-hover ? Theme.bg_lighter : Theme.bg;

                                HorizontalLayout {
                                    alignment: center;
                                    padding-left: 8px;
                                    padding-right: 8px;

                                    Text {
                                        text: preset;
                                        color: root.idle-suspend-index == idx ? Theme.bg : Theme.fg;
                                        font-size: 10px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                susp-chip-touch := TouchArea {
                                    clicked => {
                                        root.idle-suspend-index = idx;
                                        root.set-idle-suspend(idx);
                                    }
                                    mouse-cursor: pointer;
                                }
                            }

                            // Custom dropdown
                            Rectangle {
                                height: 28px;
                                min-width: 56px;
                                horizontal-stretch: 0;
                                border-radius: 4px;
                                background: root.idle-suspend-index >= 5
                                    ? Theme.accent
                                    : susp-custom-touch.has-hover ? Theme.bg_lighter : Theme.bg;

                                HorizontalLayout {
                                    alignment: center;
                                    padding-left: 8px;
                                    padding-right: 8px;

                                    Text {
                                        text: root.idle-suspend-index == 5 ? "1h"
                                            : root.idle-suspend-index == 6 ? "2h"
                                            : root.idle-suspend-index == 7 ? "3h"
                                            : root.idle-suspend-index == 8 ? "5h"
                                            : root.idle-suspend-index == 9 ? "8h"
                                            : "Custom";
                                        color: root.idle-suspend-index >= 5 ? Theme.bg : Theme.fg;
                                        font-size: 10px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                susp-custom-touch := TouchArea {
                                    clicked => {
                                        root.idle-suspend-index = root.idle-suspend-index >= 5 ?
                                            (root.idle-suspend-index >= 9 ? 5 : root.idle-suspend-index + 1) : 5;
                                        root.set-idle-suspend(root.idle-suspend-index);
                                    }
                                    mouse-cursor: pointer;
                                }
                            }
                        }
                    }
                }

                // ── Shutdown After card ──
                Rectangle {
                    border-radius: 6px;
                    background: Theme.bg_light;
                    border-width: root.highlight-setting == "Shutdown After" && root.highlight-blink-on ? 2px : 0px;
                    border-color: root.highlight-setting == "Shutdown After" && root.highlight-blink-on ? Theme.accent : transparent;
                    animate border-width { duration: 400ms; easing: ease-in-out; }
                    animate border-color { duration: 400ms; easing: ease-in-out; }
                    private property <string> _hl: root.highlight-setting;
                    init => { if _hl == "Shutdown After" { tab4-flick.viewport-y = -max(0px, self.y - 20px); } }
                    changed _hl => { if _hl == "Shutdown After" { tab4-flick.viewport-y = -max(0px, self.y - 20px); } }

                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;

                        Text {
                            text: "Shutdown after";
                            color: Theme.fg_dim;
                            font-size: 11px;
                            font-weight: 600;
                        }

                        HorizontalLayout {
                            spacing: 4px;

                            for preset[idx] in ["1 min", "5 min", "10 min", "30 min", "Never"]: Rectangle {
                                height: 28px;
                                min-width: 50px;
                                horizontal-stretch: 0;
                                border-radius: 4px;
                                background: root.idle-shutdown-index == idx
                                    ? Theme.accent
                                    : shutdown-chip-touch.has-hover ? Theme.bg_lighter : Theme.bg;

                                HorizontalLayout {
                                    alignment: center;
                                    padding-left: 8px;
                                    padding-right: 8px;

                                    Text {
                                        text: preset;
                                        color: root.idle-shutdown-index == idx ? Theme.bg : Theme.fg;
                                        font-size: 10px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                shutdown-chip-touch := TouchArea {
                                    clicked => {
                                        root.idle-shutdown-index = idx;
                                        root.set-idle-shutdown(idx);
                                    }
                                    mouse-cursor: pointer;
                                }
                            }

                            // Custom dropdown
                            Rectangle {
                                height: 28px;
                                min-width: 56px;
                                horizontal-stretch: 0;
                                border-radius: 4px;
                                background: root.idle-shutdown-index >= 5
                                    ? Theme.accent
                                    : shutdown-custom-touch.has-hover ? Theme.bg_lighter : Theme.bg;

                                HorizontalLayout {
                                    alignment: center;
                                    padding-left: 8px;
                                    padding-right: 8px;

                                    Text {
                                        text: root.idle-shutdown-index == 5 ? "1h"
                                            : root.idle-shutdown-index == 6 ? "2h"
                                            : root.idle-shutdown-index == 7 ? "3h"
                                            : root.idle-shutdown-index == 8 ? "5h"
                                            : root.idle-shutdown-index == 9 ? "8h"
                                            : "Custom";
                                        color: root.idle-shutdown-index >= 5 ? Theme.bg : Theme.fg;
                                        font-size: 10px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                shutdown-custom-touch := TouchArea {
                                    clicked => {
                                        root.idle-shutdown-index = root.idle-shutdown-index >= 5 ?
                                            (root.idle-shutdown-index >= 9 ? 5 : root.idle-shutdown-index + 1) : 5;
                                        root.set-idle-shutdown(root.idle-shutdown-index);
                                    }
                                    mouse-cursor: pointer;
                                }
                            }
                        }
                    }
                }

                // Info text
                Text {
                    text: "Changes apply immediately and persist across reboots.";
                    color: Theme.fg_dim;
                    font-size: 10px;
                }

                Rectangle { vertical-stretch: 1; }
                }
                }

                ScrollIndicator {
                    x: parent.width - 5px;
                    y: 0;
                    height: parent.height;
                    viewport-height: tab4-flick.viewport-height;
                    viewport-y: tab4-flick.viewport-y;
                    visible-height: tab4-flick.height;
                }
            }

            // ══════════════════════════════════════════════════════════════
            // KEYBINDINGS TAB
            // ══════════════════════════════════════════════════════════════

            if root.active-tab == 5: Rectangle {
                width: parent.width;
                height: parent.height;
                clip: true;

                tab5-flick := Flickable {
                    width: parent.width - 6px;
                    height: parent.height;
                    viewport-width: self.width;

                VerticalLayout {
                    padding-left: 10px;
                    padding-right: 4px;
                    spacing: 8px;

                // Header row: title + filter + section picker
                HorizontalLayout {
                    height: 30px;
                    spacing: 8px;

                    Text {
                        text: "Keybindings";
                        color: Theme.fg;
                        font-size: 14px;
                        font-weight: 600;
                        vertical-alignment: center;
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        height: 28px;
                        border-radius: 4px;
                        background: Theme.bg_light;

                        kb-filter-input := TextInput {
                            x: 8px;
                            y: 5px;
                            width: parent.width - 16px;
                            height: parent.height;
                            color: Theme.fg;
                            font-size: 12px;
                            text <=> root.kb-filter-text;
                            edited => {
                                root.kb-filter(self.text, root.kb-selected-section);
                            }
                        }

                        Text {
                            visible: root.kb-filter-text == "";
                            x: 8px;
                            y: 5px;
                            height: parent.height;
                            text: "Filter keybindings...";
                            color: Theme.fg_dim;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                    }
                }

                // Section tabs (chip bar)
                HorizontalLayout {
                    height: 26px;
                    spacing: 4px;

                    for sec[idx] in root.kb-sections: Rectangle {
                        height: 24px;
                        min-width: kb-sec-text.preferred-width + 16px;
                        border-radius: 12px;
                        background: root.kb-selected-section == idx
                            ? Theme.accent
                            : kb-sec-touch.has-hover ? Theme.bg_lighter : Theme.bg_light;

                        kb-sec-text := Text {
                            text: sec;
                            color: root.kb-selected-section == idx ? Theme.bg : Theme.fg;
                            font-size: 10px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            x: 8px;
                            width: parent.width - 16px;
                            height: parent.height;
                        }

                        kb-sec-touch := TouchArea {
                            clicked => {
                                root.kb-selected-section = idx;
                                root.kb-filter(root.kb-filter-text, idx);
                            }
                            mouse-cursor: pointer;
                        }
                    }
                }

                // Binding list
                Rectangle {
                    vertical-stretch: 1;
                    border-radius: 6px;
                    background: Theme.bg_light;
                    border-width: (root.highlight-setting == "Keybindings" || root.highlight-setting == "Keyboard Shortcuts" || root.highlight-setting == "Hotkeys" || root.highlight-setting == "Shortcut") && root.highlight-blink-on ? 2px : 0px;
                    border-color: (root.highlight-setting == "Keybindings" || root.highlight-setting == "Keyboard Shortcuts" || root.highlight-setting == "Hotkeys" || root.highlight-setting == "Shortcut") && root.highlight-blink-on ? Theme.accent : transparent;
                    animate border-width { duration: 400ms; easing: ease-in-out; }
                    animate border-color { duration: 400ms; easing: ease-in-out; }
                    clip: true;

                    Flickable {
                        width: parent.width;
                        height: parent.height;

                        VerticalLayout {
                            spacing: 1px;
                            padding: 4px;

                            for entry[idx] in root.kb-bindings: Rectangle {
                                height: root.kb-edit-idx == entry.idx ? 80px : 34px;
                                border-radius: 4px;
                                background: root.kb-edit-idx == entry.idx
                                    ? Theme.bg.transparentize(50%)
                                    : kb-row-touch.has-hover ? Theme.bg_lighter.transparentize(60%) : transparent;
                                clip: true;

                                // Normal view
                                if root.kb-edit-idx != entry.idx: HorizontalLayout {
                                    padding-left: 10px;
                                    padding-right: 6px;
                                    spacing: 8px;
                                    height: 34px;

                                    // Key combo badge — click to rebind directly
                                    Rectangle {
                                        width: 160px;
                                        height: 24px;
                                        border-radius: 4px;
                                        background: root.kb-capturing && root.kb-capture-idx == entry.idx
                                            ? Theme.warning.transparentize(50%)
                                            : kb-combo-touch.has-hover ? Theme.accent.transparentize(70%) : Theme.bg;

                                        Text {
                                            text: root.kb-capturing && root.kb-capture-idx == entry.idx
                                                ? "Press keys..."
                                                : entry.combo;
                                            color: root.kb-capturing && root.kb-capture-idx == entry.idx
                                                ? Theme.bg : Theme.accent;
                                            font-size: 11px;
                                            font-weight: 600;
                                            vertical-alignment: center;
                                            horizontal-alignment: center;
                                            width: parent.width;
                                            height: parent.height;
                                            overflow: elide;
                                        }

                                        kb-combo-touch := TouchArea {
                                            clicked => {
                                                root.kb-capture-idx = entry.idx;
                                                root.kb-capturing = true;
                                                root.kb-edit-combo(entry.idx);
                                            }
                                            mouse-cursor: pointer;
                                        }

                                        y: 5px;
                                    }

                                    // Description
                                    Text {
                                        horizontal-stretch: 1;
                                        text: entry.description;
                                        color: Theme.fg;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }

                                    // Submap tag
                                    if entry.submap != "": Rectangle {
                                        width: 60px;
                                        height: 18px;
                                        border-radius: 3px;
                                        background: Theme.warning.transparentize(70%);
                                        y: 8px;

                                        Text {
                                            text: entry.submap;
                                            color: Theme.warning;
                                            font-size: 9px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            width: parent.width;
                                            height: parent.height;
                                        }
                                    }

                                    // Edit button (expand for args/delete)
                                    Rectangle {
                                        width: 28px;
                                        height: 24px;
                                        border-radius: 4px;
                                        background: kb-edit-touch.has-hover ? Theme.bg_lighter : transparent;
                                        y: 5px;

                                        Text {
                                            text: "\u{270E}";
                                            color: Theme.fg_dim;
                                            font-size: 12px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            width: parent.width;
                                            height: parent.height;
                                        }

                                        kb-edit-touch := TouchArea {
                                            clicked => { root.kb-edit-idx = entry.idx; }
                                            mouse-cursor: pointer;
                                        }
                                    }
                                }

                                // Edit view
                                if root.kb-edit-idx == entry.idx: VerticalLayout {
                                    padding: 6px;
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    spacing: 6px;

                                    HorizontalLayout {
                                        spacing: 8px;
                                        height: 28px;

                                        // Rebind button
                                        Rectangle {
                                            width: 160px;
                                            height: 26px;
                                            border-radius: 4px;
                                            background: root.kb-capturing
                                                ? Theme.warning.transparentize(50%)
                                                : kb-rebind-touch.has-hover ? Theme.accent : Theme.bg;

                                            Text {
                                                text: root.kb-capturing
                                                    ? (root.kb-capture-combo != "" ? root.kb-capture-combo : "Press keys...")
                                                    : entry.combo;
                                                color: root.kb-capturing ? Theme.bg : Theme.accent;
                                                font-size: 11px;
                                                font-weight: 600;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                                width: parent.width;
                                                height: parent.height;
                                            }

                                            kb-rebind-touch := TouchArea {
                                                clicked => {
                                                    root.kb-capture-idx = entry.idx;
                                                    root.kb-capturing = true;
                                                    root.kb-edit-combo(entry.idx);
                                                }
                                                mouse-cursor: pointer;
                                            }
                                        }

                                        Text {
                                            text: entry.description;
                                            color: Theme.fg;
                                            font-size: 12px;
                                            vertical-alignment: center;
                                            horizontal-stretch: 1;
                                            overflow: elide;
                                        }
                                    }

                                    HorizontalLayout {
                                        spacing: 6px;
                                        height: 28px;

                                        // Command field (for exec bindings)
                                        if entry.is-exec: Rectangle {
                                            horizontal-stretch: 1;
                                            height: 26px;
                                            border-radius: 4px;
                                            background: Theme.bg;

                                            kb-args-input := TextInput {
                                                x: 8px;
                                                y: 5px;
                                                width: parent.width - 16px;
                                                height: parent.height;
                                                color: Theme.fg;
                                                font-size: 11px;
                                                text: entry.args;
                                                accepted => {
                                                    root.kb-edit-args(entry.idx, self.text);
                                                }
                                            }
                                        }

                                        if !entry.is-exec: Text {
                                            horizontal-stretch: 1;
                                            text: entry.dispatcher + " " + entry.args;
                                            color: Theme.fg_dim;
                                            font-size: 11px;
                                            vertical-alignment: center;
                                            overflow: elide;
                                        }

                                        // Delete button
                                        Rectangle {
                                            width: 60px;
                                            height: 26px;
                                            border-radius: 4px;
                                            background: kb-del-touch.has-hover ? Theme.danger : Theme.bg;

                                            Text {
                                                text: "Delete";
                                                color: kb-del-touch.has-hover ? white : Theme.danger;
                                                font-size: 11px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                                width: parent.width;
                                                height: parent.height;
                                            }

                                            kb-del-touch := TouchArea {
                                                clicked => {
                                                    root.kb-edit-idx = -1;
                                                    root.kb-remove(entry.idx);
                                                }
                                                mouse-cursor: pointer;
                                            }
                                        }

                                        // Done button
                                        Rectangle {
                                            width: 50px;
                                            height: 26px;
                                            border-radius: 4px;
                                            background: kb-done-touch.has-hover ? Theme.success : Theme.bg;

                                            Text {
                                                text: "Done";
                                                color: kb-done-touch.has-hover ? Theme.bg : Theme.success;
                                                font-size: 11px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                                width: parent.width;
                                                height: parent.height;
                                            }

                                            kb-done-touch := TouchArea {
                                                clicked => { root.kb-edit-idx = -1; }
                                                mouse-cursor: pointer;
                                            }
                                        }
                                    }
                                }

                                kb-row-touch := TouchArea {
                                    // Only handle clicks in normal mode
                                    enabled: root.kb-edit-idx != entry.idx;
                                }
                            }

                            if root.kb-bindings.length == 0: Text {
                                text: "No keybindings found. Check that bindings.conf exists.";
                                color: Theme.fg_dim;
                                font-size: 12px;
                                horizontal-alignment: center;
                            }
                        }
                    }
                }

                // Add new binding row
                if root.kb-adding: Rectangle {
                    height: 70px;
                    border-radius: 6px;
                    background: Theme.bg_light;

                    VerticalLayout {
                        padding: 8px;
                        spacing: 6px;

                        HorizontalLayout {
                            spacing: 8px;
                            height: 26px;

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 26px;
                                border-radius: 4px;
                                background: Theme.bg;

                                TextInput {
                                    x: 8px;
                                    y: 5px;
                                    width: parent.width - 16px;
                                    height: parent.height;
                                    color: Theme.fg;
                                    font-size: 11px;
                                    text <=> root.kb-new-desc;
                                    input-type: text;
                                }

                                Text {
                                    visible: root.kb-new-desc == "";
                                    x: 8px;
                                    y: 5px;
                                    height: parent.height;
                                    text: "Description (e.g. Launch Firefox)";
                                    color: Theme.fg_dim;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            height: 26px;

                            Rectangle {
                                horizontal-stretch: 1;
                                height: 26px;
                                border-radius: 4px;
                                background: Theme.bg;

                                TextInput {
                                    x: 8px;
                                    y: 5px;
                                    width: parent.width - 16px;
                                    height: parent.height;
                                    color: Theme.fg;
                                    font-size: 11px;
                                    text <=> root.kb-new-cmd;
                                    input-type: text;
                                }

                                Text {
                                    visible: root.kb-new-cmd == "";
                                    x: 8px;
                                    y: 5px;
                                    height: parent.height;
                                    text: "Command (e.g. firefox)";
                                    color: Theme.fg_dim;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                }
                            }

                            Rectangle {
                                width: 50px;
                                height: 26px;
                                border-radius: 4px;
                                background: kb-add-ok-touch.has-hover ? Theme.success : Theme.bg_lighter;

                                Text {
                                    text: "Add";
                                    color: kb-add-ok-touch.has-hover ? Theme.bg : Theme.fg;
                                    font-size: 11px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    width: parent.width;
                                    height: parent.height;
                                }

                                kb-add-ok-touch := TouchArea {
                                    clicked => {
                                        if root.kb-new-desc != "" && root.kb-new-cmd != "" {
                                            root.kb-add(root.kb-new-desc, root.kb-new-cmd);
                                            root.kb-new-desc = "";
                                            root.kb-new-cmd = "";
                                            root.kb-adding = false;
                                        }
                                    }
                                    mouse-cursor: pointer;
                                }
                            }

                            Rectangle {
                                width: 60px;
                                height: 26px;
                                border-radius: 4px;
                                background: kb-add-cancel-touch.has-hover ? Theme.bg_lighter : transparent;

                                Text {
                                    text: "Cancel";
                                    color: Theme.fg_dim;
                                    font-size: 11px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    width: parent.width;
                                    height: parent.height;
                                }

                                kb-add-cancel-touch := TouchArea {
                                    clicked => { root.kb-adding = false; }
                                    mouse-cursor: pointer;
                                }
                            }
                        }
                    }
                }

                // Footer: status + action buttons
                HorizontalLayout {
                    height: 28px;
                    spacing: 6px;

                    Text {
                        text: root.kb-status-text;
                        color: Theme.fg_dim;
                        font-size: 10px;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }

                    // Add binding
                    Rectangle {
                        height: 26px;
                        min-width: 80px;
                        border-radius: 4px;
                        background: kb-add-btn-touch.has-hover ? Theme.accent : Theme.bg_light;

                        Text {
                            text: "+ Add";
                            color: kb-add-btn-touch.has-hover ? Theme.bg : Theme.fg;
                            font-size: 11px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }

                        kb-add-btn-touch := TouchArea {
                            clicked => { root.kb-adding = !root.kb-adding; }
                            mouse-cursor: pointer;
                        }
                    }

                    // Open in editor
                    Rectangle {
                        height: 26px;
                        min-width: 80px;
                        border-radius: 4px;
                        background: kb-editor-touch.has-hover ? Theme.bg_lighter : Theme.bg_light;

                        Text {
                            text: "Edit File";
                            color: kb-editor-touch.has-hover ? Theme.fg : Theme.fg_dim;
                            font-size: 11px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }

                        kb-editor-touch := TouchArea {
                            clicked => { root.kb-open-editor(); }
                            mouse-cursor: pointer;
                        }
                    }

                    // Save
                    Rectangle {
                        height: 26px;
                        min-width: 60px;
                        border-radius: 4px;
                        background: !root.kb-has-changes
                            ? Theme.bg_light.darker(0.2)
                            : kb-save-touch.has-hover ? Theme.success : Theme.bg_light;

                        Text {
                            text: "Save";
                            color: !root.kb-has-changes
                                ? Theme.fg_dim.darker(0.3)
                                : kb-save-touch.has-hover ? Theme.bg : Theme.fg;
                            font-size: 11px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }

                        kb-save-touch := TouchArea {
                            enabled: root.kb-has-changes;
                            mouse-cursor: root.kb-has-changes ? pointer : default;
                            clicked => { root.kb-save(); }
                        }
                    }

                    // Revert
                    Rectangle {
                        height: 26px;
                        min-width: 60px;
                        border-radius: 4px;
                        background: !root.kb-has-changes
                            ? Theme.bg_light.darker(0.2)
                            : kb-revert-touch.has-hover ? Theme.warning : Theme.bg_light;

                        Text {
                            text: "Revert";
                            color: !root.kb-has-changes
                                ? Theme.fg_dim.darker(0.3)
                                : kb-revert-touch.has-hover ? Theme.bg : Theme.fg;
                            font-size: 11px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }

                        kb-revert-touch := TouchArea {
                            enabled: root.kb-has-changes;
                            mouse-cursor: root.kb-has-changes ? pointer : default;
                            clicked => { root.kb-revert(); }
                        }
                    }
                }
                }
                }

                ScrollIndicator {
                    x: parent.width - 5px;
                    y: 0;
                    height: parent.height;
                    viewport-height: tab5-flick.viewport-height;
                    viewport-y: tab5-flick.viewport-y;
                    visible-height: tab5-flick.height;
                }
            }

            // ══════════════════════════════════════════════════════════════
            // TASKBAR TAB
            // ══════════════════════════════════════════════════════════════

            if root.active-tab == 6: Rectangle {
                width: parent.width;
                height: parent.height;
                clip: true;

                tab6-flick := Flickable {
                    width: parent.width - 6px;
                    height: parent.height;
                    viewport-width: self.width;

                VerticalLayout {
                    padding-left: 10px;
                    padding-right: 4px;
                    spacing: 12px;

                Text {
                    text: "Taskbar";
                    color: Theme.fg;
                    font-size: 14px;
                    font-weight: 600;
                }

                // ── Workspace Count card ──
                Rectangle {
                    border-radius: 6px;
                    background: Theme.bg_light;
                    border-width: root.highlight-setting == "Workspace Count" && root.highlight-blink-on ? 2px : 0px;
                    border-color: root.highlight-setting == "Workspace Count" && root.highlight-blink-on ? Theme.accent : transparent;
                    animate border-width { duration: 400ms; easing: ease-in-out; }
                    animate border-color { duration: 400ms; easing: ease-in-out; }

                    VerticalLayout {
                        padding: 12px;
                        spacing: 10px;

                        Text {
                            text: "Workspace Count";
                            color: Theme.fg_dim;
                            font-size: 11px;
                            font-weight: 600;
                        }

                        Text {
                            text: "Number of workspace indicators shown in the taskbar (1–10).";
                            color: Theme.fg_dim;
                            font-size: 10px;
                            wrap: word-wrap;
                        }

                        HorizontalLayout {
                            spacing: 12px;
                            alignment: start;

                            Text {
                                text: "1";
                                color: Theme.fg_dim;
                                font-size: 11px;
                                vertical-alignment: center;
                            }

                            Rectangle {
                                width: 220px;
                                height: 30px;
                                border-radius: 4px;
                                background: Theme.bg_lighter.transparentize(50%);

                                // Track
                                Rectangle {
                                    x: 8px;
                                    y: (parent.height - 4px) / 2;
                                    width: parent.width - 16px;
                                    height: 4px;
                                    border-radius: 2px;
                                    background: Theme.bg_lighter;

                                    // Filled portion
                                    Rectangle {
                                        x: 0;
                                        y: 0;
                                        width: parent.width * (root.tb-ws-count - 1) / 9;
                                        height: parent.height;
                                        border-radius: 2px;
                                        background: Theme.accent;
                                    }
                                }

                                // Thumb
                                Rectangle {
                                    x: 8px + (parent.width - 16px - self.width) * (root.tb-ws-count - 1) / 9;
                                    y: (parent.height - self.height) / 2;
                                    width: 16px;
                                    height: 16px;
                                    border-radius: 8px;
                                    background: ws-slider-touch.has-hover ? Theme.accent.brighter(20%)
                                                : ws-slider-touch.pressed ? Theme.accent.brighter(40%)
                                                : Theme.accent;

                                    ws-slider-touch := TouchArea {
                                        mouse-cursor: pointer;
                                    }
                                }

                                // Click area for the entire slider track
                                ws-track-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        // Map click x to 1–10
                                        root.tb-ws-count = clamp(round(1 + 9 * (self.mouse-x - 8px) / (self.width - 16px)), 1, 10);
                                        root.tb-set-ws-count(root.tb-ws-count);
                                    }
                                    moved => {
                                        if self.pressed {
                                            root.tb-ws-count = clamp(round(1 + 9 * (self.mouse-x - 8px) / (self.width - 16px)), 1, 10);
                                            root.tb-set-ws-count(root.tb-ws-count);
                                        }
                                    }
                                }
                            }

                            Text {
                                text: "10";
                                color: Theme.fg_dim;
                                font-size: 11px;
                                vertical-alignment: center;
                            }

                            // Current value badge
                            Rectangle {
                                width: 32px;
                                height: 24px;
                                border-radius: 4px;
                                background: Theme.accent.transparentize(70%);

                                Text {
                                    text: root.tb-ws-count;
                                    color: Theme.accent;
                                    font-size: 12px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                // ── Workspace Position card ──
                Rectangle {
                    border-radius: 6px;
                    background: Theme.bg_light;
                    border-width: root.highlight-setting == "Workspace Position" && root.highlight-blink-on ? 2px : 0px;
                    border-color: root.highlight-setting == "Workspace Position" && root.highlight-blink-on ? Theme.accent : transparent;
                    animate border-width { duration: 400ms; easing: ease-in-out; }
                    animate border-color { duration: 400ms; easing: ease-in-out; }

                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;

                        Text {
                            text: "Workspace Position";
                            color: Theme.fg_dim;
                            font-size: 11px;
                            font-weight: 600;
                        }

                        Text {
                            text: "Place workspace indicators in the center of the bar or on the left next to the start button.";
                            color: Theme.fg_dim;
                            font-size: 10px;
                            wrap: word-wrap;
                        }

                        // Center option
                        Rectangle {
                            height: 40px;
                            border-radius: 4px;
                            background: root.tb-ws-position-index == 0
                                ? Theme.accent.transparentize(70%)
                                : ws-pos-center-touch.has-hover ? Theme.bg_lighter : transparent;

                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 10px;

                                VerticalLayout {
                                    alignment: center;
                                    width: 14px;
                                    Rectangle {
                                        width: 14px; height: 14px;
                                        border-radius: 7px;
                                        border-width: 1.5px;
                                        border-color: root.tb-ws-position-index == 0 ? Theme.accent : Theme.fg_dim;
                                        background: transparent;
                                        Rectangle {
                                            visible: root.tb-ws-position-index == 0;
                                            x: 3px; y: 3px; width: 8px; height: 8px;
                                            border-radius: 4px;
                                            background: Theme.accent;
                                        }
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 2px;
                                    Text { text: "Center"; color: Theme.fg; font-size: 12px; }
                                    Text { text: "Workspace dots centered in the taskbar"; color: Theme.fg_dim; font-size: 10px; }
                                }
                            }

                            ws-pos-center-touch := TouchArea {
                                clicked => {
                                    root.tb-ws-position-index = 0;
                                    root.tb-set-ws-position(0);
                                }
                                mouse-cursor: pointer;
                            }
                        }

                        // Left option
                        Rectangle {
                            height: 40px;
                            border-radius: 4px;
                            background: root.tb-ws-position-index == 1
                                ? Theme.accent.transparentize(70%)
                                : ws-pos-left-touch.has-hover ? Theme.bg_lighter : transparent;

                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 10px;

                                VerticalLayout {
                                    alignment: center;
                                    width: 14px;
                                    Rectangle {
                                        width: 14px; height: 14px;
                                        border-radius: 7px;
                                        border-width: 1.5px;
                                        border-color: root.tb-ws-position-index == 1 ? Theme.accent : Theme.fg_dim;
                                        background: transparent;
                                        Rectangle {
                                            visible: root.tb-ws-position-index == 1;
                                            x: 3px; y: 3px; width: 8px; height: 8px;
                                            border-radius: 4px;
                                            background: Theme.accent;
                                        }
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 2px;
                                    Text { text: "Left"; color: Theme.fg; font-size: 12px; }
                                    Text { text: "Workspace dots next to the start button"; color: Theme.fg_dim; font-size: 10px; }
                                }
                            }

                            ws-pos-left-touch := TouchArea {
                                clicked => {
                                    root.tb-ws-position-index = 1;
                                    root.tb-set-ws-position(1);
                                }
                                mouse-cursor: pointer;
                            }
                        }
                    }
                }

                // ── Workspace Spacing card ──
                Rectangle {
                    border-radius: 6px;
                    background: Theme.bg_light;
                    border-width: root.highlight-setting == "Workspace Spacing" && root.highlight-blink-on ? 2px : 0px;
                    border-color: root.highlight-setting == "Workspace Spacing" && root.highlight-blink-on ? Theme.accent : transparent;
                    animate border-width { duration: 400ms; easing: ease-in-out; }
                    animate border-color { duration: 400ms; easing: ease-in-out; }
                    private property <string> _hl: root.highlight-setting;
                    init => { if _hl == "Workspace Spacing" { tab6-flick.viewport-y = -max(0px, self.y - 20px); } }
                    changed _hl => { if _hl == "Workspace Spacing" { tab6-flick.viewport-y = -max(0px, self.y - 20px); } }

                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;

                        Text {
                            text: "Workspace Spacing";
                            color: Theme.fg_dim;
                            font-size: 11px;
                            font-weight: 600;
                        }

                        Text {
                            text: "Gap in pixels between workspace indicators (1-10).";
                            color: Theme.fg_dim;
                            font-size: 10px;
                            wrap: word-wrap;
                        }

                        HorizontalLayout {
                            spacing: 12px;
                            alignment: start;

                            Text {
                                text: "1";
                                color: Theme.fg_dim;
                                font-size: 11px;
                                vertical-alignment: center;
                            }

                            Rectangle {
                                width: 220px;
                                height: 30px;
                                border-radius: 4px;
                                background: Theme.bg_lighter.transparentize(50%);

                                // Track
                                Rectangle {
                                    x: 8px;
                                    y: (parent.height - 4px) / 2;
                                    width: parent.width - 16px;
                                    height: 4px;
                                    border-radius: 2px;
                                    background: Theme.bg_lighter;

                                    // Filled portion
                                    Rectangle {
                                        x: 0;
                                        y: 0;
                                        width: parent.width * (root.tb-ws-spacing - 1) / 9;
                                        height: parent.height;
                                        border-radius: 2px;
                                        background: Theme.accent;
                                    }
                                }

                                // Thumb
                                Rectangle {
                                    x: 8px + (parent.width - 16px - self.width) * (root.tb-ws-spacing - 1) / 9;
                                    y: (parent.height - self.height) / 2;
                                    width: 16px;
                                    height: 16px;
                                    border-radius: 8px;
                                    background: ws-spacing-slider-touch.has-hover ? Theme.accent.brighter(20%)
                                                : ws-spacing-slider-touch.pressed ? Theme.accent.brighter(40%)
                                                : Theme.accent;

                                    ws-spacing-slider-touch := TouchArea {
                                        mouse-cursor: pointer;
                                    }
                                }

                                // Click area for the entire slider track
                                ws-spacing-track-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.tb-ws-spacing = clamp(round(1 + 9 * (self.mouse-x - 8px) / (self.width - 16px)), 1, 10);
                                        root.tb-set-ws-spacing(root.tb-ws-spacing);
                                    }
                                    moved => {
                                        if self.pressed {
                                            root.tb-ws-spacing = clamp(round(1 + 9 * (self.mouse-x - 8px) / (self.width - 16px)), 1, 10);
                                            root.tb-set-ws-spacing(root.tb-ws-spacing);
                                        }
                                    }
                                }
                            }

                            Text {
                                text: "10";
                                color: Theme.fg_dim;
                                font-size: 11px;
                                vertical-alignment: center;
                            }

                            // Current value badge
                            Rectangle {
                                width: 38px;
                                height: 24px;
                                border-radius: 4px;
                                background: Theme.accent.transparentize(70%);

                                Text {
                                    text: root.tb-ws-spacing + "px";
                                    color: Theme.accent;
                                    font-size: 12px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                // ── Workspace Style card ──
                Rectangle {
                    border-radius: 6px;
                    background: Theme.bg_light;
                    border-width: root.highlight-setting == "Workspace Style" && root.highlight-blink-on ? 2px : 0px;
                    border-color: root.highlight-setting == "Workspace Style" && root.highlight-blink-on ? Theme.accent : transparent;
                    animate border-width { duration: 400ms; easing: ease-in-out; }
                    animate border-color { duration: 400ms; easing: ease-in-out; }
                    private property <string> _hl: root.highlight-setting;
                    init => { if _hl == "Workspace Style" { tab6-flick.viewport-y = -max(0px, self.y - 20px); } }
                    changed _hl => { if _hl == "Workspace Style" { tab6-flick.viewport-y = -max(0px, self.y - 20px); } }

                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;

                        Text {
                            text: "Workspace Style";
                            color: Theme.fg_dim;
                            font-size: 11px;
                            font-weight: 600;
                        }

                        // Numbers option
                        Rectangle {
                            height: 40px;
                            border-radius: 4px;
                            background: root.tb-ws-style-index == 0
                                ? Theme.accent.transparentize(70%)
                                : ws-style-numbers-touch.has-hover ? Theme.bg_lighter : transparent;

                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 10px;

                                VerticalLayout {
                                    alignment: center;
                                    width: 14px;
                                    Rectangle {
                                        width: 14px; height: 14px;
                                        border-radius: 7px;
                                        border-width: 1.5px;
                                        border-color: root.tb-ws-style-index == 0 ? Theme.accent : Theme.fg_dim;
                                        background: transparent;
                                        Rectangle {
                                            visible: root.tb-ws-style-index == 0;
                                            x: 3px; y: 3px; width: 8px; height: 8px;
                                            border-radius: 4px;
                                            background: Theme.accent;
                                        }
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 2px;
                                    Text { text: "Numbers"; color: Theme.fg; font-size: 12px; }
                                    Text { text: "Numbered dots showing workspace index"; color: Theme.fg_dim; font-size: 10px; }
                                }
                            }

                            ws-style-numbers-touch := TouchArea {
                                clicked => {
                                    root.tb-ws-style-index = 0;
                                    root.tb-set-ws-style(0);
                                }
                                mouse-cursor: pointer;
                            }
                        }

                        // Squares option
                        Rectangle {
                            height: 40px;
                            border-radius: 4px;
                            background: root.tb-ws-style-index == 1
                                ? Theme.accent.transparentize(70%)
                                : ws-style-squares-touch.has-hover ? Theme.bg_lighter : transparent;

                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 10px;

                                VerticalLayout {
                                    alignment: center;
                                    width: 14px;
                                    Rectangle {
                                        width: 14px; height: 14px;
                                        border-radius: 7px;
                                        border-width: 1.5px;
                                        border-color: root.tb-ws-style-index == 1 ? Theme.accent : Theme.fg_dim;
                                        background: transparent;
                                        Rectangle {
                                            visible: root.tb-ws-style-index == 1;
                                            x: 3px; y: 3px; width: 8px; height: 8px;
                                            border-radius: 4px;
                                            background: Theme.accent;
                                        }
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    spacing: 2px;
                                    Text { text: "Squares"; color: Theme.fg; font-size: 12px; }
                                    Text { text: "Compact grid of colored squares"; color: Theme.fg_dim; font-size: 10px; }
                                }
                            }

                            ws-style-squares-touch := TouchArea {
                                clicked => {
                                    root.tb-ws-style-index = 1;
                                    root.tb-set-ws-style(1);
                                }
                                mouse-cursor: pointer;
                            }
                        }
                    }
                }

                // ── Clock Format card ──────────────────────────────────
                Rectangle {
                    border-radius: 6px;
                    background: Theme.bg_light;
                    border-width: root.highlight-setting == "Clock Format" && root.highlight-blink-on ? 2px : 0px;
                    border-color: root.highlight-setting == "Clock Format" && root.highlight-blink-on ? Theme.accent : transparent;
                    animate border-width { duration: 400ms; easing: ease-in-out; }
                    animate border-color { duration: 400ms; easing: ease-in-out; }
                    private property <string> _hl: root.highlight-setting;
                    init => {
                        if _hl == "Clock Format" || _hl == "Time Format" || _hl == "Date Format"
                            || _hl == "24-hour" || _hl == "AM PM" {
                            tab6-flick.viewport-y = -max(0px, self.y - 20px);
                        }
                    }
                    changed _hl => {
                        if _hl == "Clock Format" || _hl == "Time Format" || _hl == "Date Format"
                            || _hl == "24-hour" || _hl == "AM PM" {
                            tab6-flick.viewport-y = -max(0px, self.y - 20px);
                        }
                    }

                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;

                        Text {
                            text: "Clock Format";
                            color: Theme.fg_dim;
                            font-size: 11px;
                            font-weight: 600;
                        }

                        Text {
                            text: "Choose what appears in the taskbar clock. Two-line formats show time larger with a smaller line below.";
                            color: Theme.fg_dim;
                            font-size: 10px;
                            wrap: word-wrap;
                        }

                        // ── Display format options ──────────────────────

                        // Time only
                        Rectangle {
                            height: 40px;
                            border-radius: 4px;
                            background: root.tb-clock-format-index == 0
                                ? Theme.accent.transparentize(70%)
                                : clock-fmt-time-touch.has-hover ? Theme.bg_lighter : transparent;
                            HorizontalLayout {
                                padding-left: 10px; padding-right: 10px; spacing: 10px;
                                VerticalLayout {
                                    alignment: center; width: 14px;
                                    Rectangle {
                                        width: 14px; height: 14px; border-radius: 7px;
                                        border-width: 1.5px;
                                        border-color: root.tb-clock-format-index == 0 ? Theme.accent : Theme.fg_dim;
                                        background: transparent;
                                        Rectangle {
                                            visible: root.tb-clock-format-index == 0;
                                            x: 3px; y: 3px; width: 8px; height: 8px;
                                            border-radius: 4px; background: Theme.accent;
                                        }
                                    }
                                }
                                VerticalLayout {
                                    alignment: center; spacing: 1px;
                                    Text { text: "Time only"; color: Theme.fg; font-size: 12px; }
                                    Text { text: "e.g.  3:42 PM"; color: Theme.fg_dim; font-size: 10px; }
                                }
                            }
                            clock-fmt-time-touch := TouchArea {
                                clicked => { root.tb-clock-format-index = 0; root.tb-set-clock-format(0); }
                                mouse-cursor: pointer;
                            }
                        }

                        // Time & day of week
                        Rectangle {
                            height: 40px;
                            border-radius: 4px;
                            background: root.tb-clock-format-index == 1
                                ? Theme.accent.transparentize(70%)
                                : clock-fmt-dow-touch.has-hover ? Theme.bg_lighter : transparent;
                            HorizontalLayout {
                                padding-left: 10px; padding-right: 10px; spacing: 10px;
                                VerticalLayout {
                                    alignment: center; width: 14px;
                                    Rectangle {
                                        width: 14px; height: 14px; border-radius: 7px;
                                        border-width: 1.5px;
                                        border-color: root.tb-clock-format-index == 1 ? Theme.accent : Theme.fg_dim;
                                        background: transparent;
                                        Rectangle {
                                            visible: root.tb-clock-format-index == 1;
                                            x: 3px; y: 3px; width: 8px; height: 8px;
                                            border-radius: 4px; background: Theme.accent;
                                        }
                                    }
                                }
                                VerticalLayout {
                                    alignment: center; spacing: 1px;
                                    Text { text: "Time & day of week"; color: Theme.fg; font-size: 12px; }
                                    Text { text: "e.g.  3:42 PM  /  Wed"; color: Theme.fg_dim; font-size: 10px; }
                                }
                            }
                            clock-fmt-dow-touch := TouchArea {
                                clicked => { root.tb-clock-format-index = 1; root.tb-set-clock-format(1); }
                                mouse-cursor: pointer;
                            }
                        }

                        // Time & date
                        Rectangle {
                            height: 40px;
                            border-radius: 4px;
                            background: root.tb-clock-format-index == 2
                                ? Theme.accent.transparentize(70%)
                                : clock-fmt-date-touch.has-hover ? Theme.bg_lighter : transparent;
                            HorizontalLayout {
                                padding-left: 10px; padding-right: 10px; spacing: 10px;
                                VerticalLayout {
                                    alignment: center; width: 14px;
                                    Rectangle {
                                        width: 14px; height: 14px; border-radius: 7px;
                                        border-width: 1.5px;
                                        border-color: root.tb-clock-format-index == 2 ? Theme.accent : Theme.fg_dim;
                                        background: transparent;
                                        Rectangle {
                                            visible: root.tb-clock-format-index == 2;
                                            x: 3px; y: 3px; width: 8px; height: 8px;
                                            border-radius: 4px; background: Theme.accent;
                                        }
                                    }
                                }
                                VerticalLayout {
                                    alignment: center; spacing: 1px;
                                    Text { text: "Time & date"; color: Theme.fg; font-size: 12px; }
                                    Text { text: "e.g.  3:42 PM  /  3/26"; color: Theme.fg_dim; font-size: 10px; }
                                }
                            }
                            clock-fmt-date-touch := TouchArea {
                                clicked => { root.tb-clock-format-index = 2; root.tb-set-clock-format(2); }
                                mouse-cursor: pointer;
                            }
                        }

                        Rectangle { height: 1px; background: Theme.bg_lighter; }

                        // ── Time format (24h vs AM/PM) ──────────────────
                        Text {
                            text: "Time Format";
                            color: Theme.fg_dim;
                            font-size: 11px;
                            font-weight: 600;
                        }

                        HorizontalLayout {
                            spacing: 8px;

                            // 24-hour
                            Rectangle {
                                height: 36px; border-radius: 4px; horizontal-stretch: 1;
                                background: root.tb-clock-24h
                                    ? Theme.accent.transparentize(70%)
                                    : clock-24h-touch.has-hover ? Theme.bg_lighter : transparent;
                                HorizontalLayout {
                                    padding-left: 10px; spacing: 8px;
                                    VerticalLayout {
                                        alignment: center; width: 14px;
                                        Rectangle {
                                            width: 14px; height: 14px; border-radius: 7px;
                                            border-width: 1.5px;
                                            border-color: root.tb-clock-24h ? Theme.accent : Theme.fg_dim;
                                            background: transparent;
                                            Rectangle {
                                                visible: root.tb-clock-24h;
                                                x: 3px; y: 3px; width: 8px; height: 8px;
                                                border-radius: 4px; background: Theme.accent;
                                            }
                                        }
                                    }
                                    Text { text: "24-hour"; color: Theme.fg; font-size: 12px; vertical-alignment: center; }
                                }
                                clock-24h-touch := TouchArea {
                                    clicked => { root.tb-clock-24h = true; root.tb-set-clock-24h(true); }
                                    mouse-cursor: pointer;
                                }
                            }

                            // AM / PM
                            Rectangle {
                                height: 36px; border-radius: 4px; horizontal-stretch: 1;
                                background: !root.tb-clock-24h
                                    ? Theme.accent.transparentize(70%)
                                    : clock-ampm-touch.has-hover ? Theme.bg_lighter : transparent;
                                HorizontalLayout {
                                    padding-left: 10px; spacing: 8px;
                                    VerticalLayout {
                                        alignment: center; width: 14px;
                                        Rectangle {
                                            width: 14px; height: 14px; border-radius: 7px;
                                            border-width: 1.5px;
                                            border-color: !root.tb-clock-24h ? Theme.accent : Theme.fg_dim;
                                            background: transparent;
                                            Rectangle {
                                                visible: !root.tb-clock-24h;
                                                x: 3px; y: 3px; width: 8px; height: 8px;
                                                border-radius: 4px; background: Theme.accent;
                                            }
                                        }
                                    }
                                    Text { text: "AM / PM"; color: Theme.fg; font-size: 12px; vertical-alignment: center; }
                                }
                                clock-ampm-touch := TouchArea {
                                    clicked => { root.tb-clock-24h = false; root.tb-set-clock-24h(false); }
                                    mouse-cursor: pointer;
                                }
                            }
                        }

                        // ── Date format (only when clock_format == date) ─
                        if root.tb-clock-format-index == 2: Rectangle { height: 1px; background: Theme.bg_lighter; }

                        if root.tb-clock-format-index == 2: Text {
                            text: "Date Format";
                            color: Theme.fg_dim;
                            font-size: 11px;
                            font-weight: 600;
                        }

                        if root.tb-clock-format-index == 2: GridLayout {
                            spacing: 8px;

                            Row {
                                // M/D
                                Rectangle {
                                    height: 36px; border-radius: 4px;
                                    background: root.tb-clock-date-fmt-index == 0
                                        ? Theme.accent.transparentize(70%)
                                        : clock-date-md-touch.has-hover ? Theme.bg_lighter : transparent;
                                    HorizontalLayout {
                                        padding-left: 10px; spacing: 8px;
                                        VerticalLayout {
                                            alignment: center; width: 14px;
                                            Rectangle {
                                                width: 14px; height: 14px; border-radius: 7px;
                                                border-width: 1.5px;
                                                border-color: root.tb-clock-date-fmt-index == 0 ? Theme.accent : Theme.fg_dim;
                                                background: transparent;
                                                Rectangle {
                                                    visible: root.tb-clock-date-fmt-index == 0;
                                                    x: 3px; y: 3px; width: 8px; height: 8px;
                                                    border-radius: 4px; background: Theme.accent;
                                                }
                                            }
                                        }
                                        VerticalLayout {
                                            alignment: center; spacing: 1px;
                                            Text { text: "M/D"; color: Theme.fg; font-size: 12px; }
                                            Text { text: "3/26"; color: Theme.fg_dim; font-size: 10px; }
                                        }
                                    }
                                    clock-date-md-touch := TouchArea {
                                        clicked => { root.tb-clock-date-fmt-index = 0; root.tb-set-clock-date-fmt(0); }
                                        mouse-cursor: pointer;
                                    }
                                }

                                // D/M
                                Rectangle {
                                    height: 36px; border-radius: 4px;
                                    background: root.tb-clock-date-fmt-index == 1
                                        ? Theme.accent.transparentize(70%)
                                        : clock-date-dm-touch.has-hover ? Theme.bg_lighter : transparent;
                                    HorizontalLayout {
                                        padding-left: 10px; spacing: 8px;
                                        VerticalLayout {
                                            alignment: center; width: 14px;
                                            Rectangle {
                                                width: 14px; height: 14px; border-radius: 7px;
                                                border-width: 1.5px;
                                                border-color: root.tb-clock-date-fmt-index == 1 ? Theme.accent : Theme.fg_dim;
                                                background: transparent;
                                                Rectangle {
                                                    visible: root.tb-clock-date-fmt-index == 1;
                                                    x: 3px; y: 3px; width: 8px; height: 8px;
                                                    border-radius: 4px; background: Theme.accent;
                                                }
                                            }
                                        }
                                        VerticalLayout {
                                            alignment: center; spacing: 1px;
                                            Text { text: "D/M"; color: Theme.fg; font-size: 12px; }
                                            Text { text: "26/3"; color: Theme.fg_dim; font-size: 10px; }
                                        }
                                    }
                                    clock-date-dm-touch := TouchArea {
                                        clicked => { root.tb-clock-date-fmt-index = 1; root.tb-set-clock-date-fmt(1); }
                                        mouse-cursor: pointer;
                                    }
                                }
                            }

                            Row {
                                // YYYY-MM-DD
                                Rectangle {
                                    height: 36px; border-radius: 4px;
                                    background: root.tb-clock-date-fmt-index == 2
                                        ? Theme.accent.transparentize(70%)
                                        : clock-date-iso-touch.has-hover ? Theme.bg_lighter : transparent;
                                    HorizontalLayout {
                                        padding-left: 10px; spacing: 8px;
                                        VerticalLayout {
                                            alignment: center; width: 14px;
                                            Rectangle {
                                                width: 14px; height: 14px; border-radius: 7px;
                                                border-width: 1.5px;
                                                border-color: root.tb-clock-date-fmt-index == 2 ? Theme.accent : Theme.fg_dim;
                                                background: transparent;
                                                Rectangle {
                                                    visible: root.tb-clock-date-fmt-index == 2;
                                                    x: 3px; y: 3px; width: 8px; height: 8px;
                                                    border-radius: 4px; background: Theme.accent;
                                                }
                                            }
                                        }
                                        VerticalLayout {
                                            alignment: center; spacing: 1px;
                                            Text { text: "YYYY-MM-DD"; color: Theme.fg; font-size: 12px; }
                                            Text { text: "2026-03-26"; color: Theme.fg_dim; font-size: 10px; }
                                        }
                                    }
                                    clock-date-iso-touch := TouchArea {
                                        clicked => { root.tb-clock-date-fmt-index = 2; root.tb-set-clock-date-fmt(2); }
                                        mouse-cursor: pointer;
                                    }
                                }

                                // Mon D
                                Rectangle {
                                    height: 36px; border-radius: 4px;
                                    background: root.tb-clock-date-fmt-index == 3
                                        ? Theme.accent.transparentize(70%)
                                        : clock-date-mon-touch.has-hover ? Theme.bg_lighter : transparent;
                                    HorizontalLayout {
                                        padding-left: 10px; spacing: 8px;
                                        VerticalLayout {
                                            alignment: center; width: 14px;
                                            Rectangle {
                                                width: 14px; height: 14px; border-radius: 7px;
                                                border-width: 1.5px;
                                                border-color: root.tb-clock-date-fmt-index == 3 ? Theme.accent : Theme.fg_dim;
                                                background: transparent;
                                                Rectangle {
                                                    visible: root.tb-clock-date-fmt-index == 3;
                                                    x: 3px; y: 3px; width: 8px; height: 8px;
                                                    border-radius: 4px; background: Theme.accent;
                                                }
                                            }
                                        }
                                        VerticalLayout {
                                            alignment: center; spacing: 1px;
                                            Text { text: "Mon D"; color: Theme.fg; font-size: 12px; }
                                            Text { text: "Mar 26"; color: Theme.fg_dim; font-size: 10px; }
                                        }
                                    }
                                    clock-date-mon-touch := TouchArea {
                                        clicked => { root.tb-clock-date-fmt-index = 3; root.tb-set-clock-date-fmt(3); }
                                        mouse-cursor: pointer;
                                    }
                                }
                            }
                        }
                    }
                }

                Rectangle { vertical-stretch: 1; }
                }
                }

                ScrollIndicator {
                    x: parent.width - 5px;
                    y: 0;
                    height: parent.height;
                    viewport-height: tab6-flick.viewport-height;
                    viewport-y: tab6-flick.viewport-y;
                    visible-height: tab6-flick.height;
                }
            }

            // ══════════════════════════════════════════════════════════════
            // ABOUT TAB
            // ══════════════════════════════════════════════════════════════

            if root.active-tab == 0: Rectangle {
                width: parent.width;
                height: parent.height;
                clip: true;

                tab0-flick := Flickable {
                    width: parent.width - 6px;
                    height: parent.height;
                    viewport-width: self.width;

                VerticalLayout {
                    padding-left: 10px;
                    padding-right: 4px;
                    spacing: 12px;

                Rectangle { vertical-stretch: 1; }

                // Logo / name
                VerticalLayout {
                    spacing: 4px;
                    alignment: center;

                    Text {
                        text: "smplOS";
                        color: Theme.accent;
                        font-size: 28px;
                        font-weight: 700;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: root.about-version;
                        color: Theme.fg_dim;
                        font-size: 13px;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: "A simple, fast Arch-based desktop";
                        color: Theme.fg_dim;
                        font-size: 11px;
                        horizontal-alignment: center;
                    }
                }

                // System info card
                Rectangle {
                    border-radius: 6px;
                    background: Theme.bg_light;
                    border-width: (root.highlight-setting == "About smplOS" || root.highlight-setting == "Version" || root.highlight-setting == "Hostname" || root.highlight-setting == "Kernel" || root.highlight-setting == "Uptime" || root.highlight-setting == "Compositor") && root.highlight-blink-on ? 2px : 0px;
                    border-color: (root.highlight-setting == "About smplOS" || root.highlight-setting == "Version" || root.highlight-setting == "Hostname" || root.highlight-setting == "Kernel" || root.highlight-setting == "Uptime" || root.highlight-setting == "Compositor") && root.highlight-blink-on ? Theme.accent : transparent;
                    animate border-width { duration: 400ms; easing: ease-in-out; }
                    animate border-color { duration: 400ms; easing: ease-in-out; }

                    VerticalLayout {
                        padding: 14px;
                        spacing: 10px;

                        // Hostname
                        HorizontalLayout {
                            spacing: 8px;
                            Text { text: "Hostname"; color: Theme.fg_dim; font-size: 12px; vertical-alignment: center; width: 80px; }
                            Text { text: root.about-hostname; color: Theme.fg; font-size: 12px; vertical-alignment: center; }
                        }

                        Rectangle { height: 1px; background: Theme.bg_lighter; }

                        // Kernel
                        HorizontalLayout {
                            spacing: 8px;
                            Text { text: "Kernel"; color: Theme.fg_dim; font-size: 12px; vertical-alignment: center; width: 80px; }
                            Text { text: root.about-kernel; color: Theme.fg; font-size: 12px; vertical-alignment: center; }
                        }

                        Rectangle { height: 1px; background: Theme.bg_lighter; }

                        // Uptime
                        HorizontalLayout {
                            spacing: 8px;
                            Text { text: "Uptime"; color: Theme.fg_dim; font-size: 12px; vertical-alignment: center; width: 80px; }
                            Text { text: root.about-uptime; color: Theme.fg; font-size: 12px; vertical-alignment: center; }
                        }

                        Rectangle { height: 1px; background: Theme.bg_lighter; }

                        // Compositor
                        HorizontalLayout {
                            spacing: 8px;
                            Text { text: "Compositor"; color: Theme.fg_dim; font-size: 12px; vertical-alignment: center; width: 80px; }
                            Text { text: "Hyprland"; color: Theme.fg; font-size: 12px; vertical-alignment: center; }
                        }

                        Rectangle { height: 1px; background: Theme.bg_lighter; }

                        // CPU
                        HorizontalLayout {
                            spacing: 8px;
                            Text { text: "CPU"; color: Theme.fg_dim; font-size: 12px; vertical-alignment: center; width: 80px; }
                            Text { text: root.about-cpu; color: Theme.fg; font-size: 12px; vertical-alignment: center; }
                        }

                        Rectangle { height: 1px; background: Theme.bg_lighter; }

                        // RAM
                        HorizontalLayout {
                            spacing: 8px;
                            Text { text: "Memory"; color: Theme.fg_dim; font-size: 12px; vertical-alignment: center; width: 80px; }
                            Text { text: root.about-ram; color: Theme.fg; font-size: 12px; vertical-alignment: center; }
                        }

                        if root.about-gpu != "": Rectangle { height: 1px; background: Theme.bg_lighter; }

                        // GPU (if detected)
                        if root.about-gpu != "": HorizontalLayout {
                            spacing: 8px;
                            Text { text: "GPU"; color: Theme.fg_dim; font-size: 12px; vertical-alignment: center; width: 80px; }
                            Text { text: root.about-gpu; color: Theme.fg; font-size: 12px; vertical-alignment: center; }
                        }
                    }
                }

                Text {
                    text: "Part of smplOS";
                    color: Theme.fg_dim;
                    font-size: 10px;
                    horizontal-alignment: center;
                }

                Rectangle { vertical-stretch: 1; }
                }
                }

                ScrollIndicator {
                    x: parent.width - 5px;
                    y: 0;
                    height: parent.height;
                    viewport-height: tab0-flick.viewport-height;
                    viewport-y: tab0-flick.viewport-y;
                    visible-height: tab0-flick.height;
                }
            }



            // ══════════════════════════════════════════════════════════════
            // WI-FI TAB
            // ══════════════════════════════════════════════════════════════

            if root.active-tab == 7: Rectangle {
                width: parent.width;
                height: parent.height;
                clip: true;

                HorizontalLayout {
                    spacing: 0px;
                    width: parent.width;
                    height: parent.height;

                    // ── Left: network list ────────────────────────────────
                    Rectangle {
                        width: 255px;
                        vertical-stretch: 1;

                        VerticalLayout {
                            width: parent.width;
                            height: parent.height;
                            padding: 10px;
                            spacing: 6px;

                            // Header
                            HorizontalLayout {
                                spacing: 6px;
                                alignment: start;

                                Text {
                                    text: "Wi-Fi";
                                    color: Theme.fg;
                                    font-size: 14px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }

                                // Airplane mode toggle
                                HorizontalLayout {
                                    spacing: 4px;
                                    alignment: center;
                                    opacity: root.wifi-no-hardware ? 0.35 : 1.0;
                                    Text {
                                        text: "✈";
                                        color: root.wifi-no-hardware
                                            ? Theme.fg_dim
                                            : root.wifi-airplane-mode
                                                ? Theme.danger
                                                : Theme.fg_dim;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                    }
                                    // Toggle rail
                                    airplane-rail := Rectangle {
                                        width: 32px;
                                        height: 18px;
                                        border-radius: 9px;
                                        background: root.wifi-no-hardware
                                            ? Theme.bg_lighter
                                            : root.wifi-airplane-mode
                                                ? Theme.danger.transparentize(50%)
                                                : Theme.accent.transparentize(50%);
                                        animate background { duration: 150ms; }
                                        // Thumb
                                        Rectangle {
                                            width: 12px;
                                            height: 12px;
                                            border-radius: 6px;
                                            x: root.wifi-airplane-mode ? 3px : 17px;
                                            y: 3px;
                                            background: root.wifi-no-hardware
                                                ? Theme.fg_dim
                                                : root.wifi-airplane-mode
                                                    ? Theme.danger
                                                    : Theme.accent;
                                            animate x { duration: 150ms; }
                                        }
                                        airplane-ta := TouchArea {
                                            clicked => {
                                                if (!root.wifi-no-hardware) {
                                                    root.wifi-airplane-mode = !root.wifi-airplane-mode;
                                                    root.wifi-set-airplane(root.wifi-airplane-mode);
                                                }
                                            }
                                            mouse-cursor: root.wifi-no-hardware ? default : pointer;
                                        }
                                    }
                                }

                                // Scan button
                                Rectangle {
                                    width: 68px;
                                    height: 26px;
                                    border-radius: 4px;
                                    background: scan-btn-ta.has-hover
                                        ? Theme.accent.transparentize(60%)
                                        : Theme.bg_light;

                                    HorizontalLayout {
                                        padding-left: 6px;
                                        padding-right: 6px;
                                        spacing: 4px;
                                        alignment: center;
                                        Text {
                                            text: root.wifi-scanning ? "…" : "⟳";
                                            color: Theme.accent;
                                            font-size: 13px;
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: root.wifi-scanning ? "Scanning" : "Scan";
                                            color: Theme.fg;
                                            font-size: 11px;
                                            vertical-alignment: center;
                                        }
                                    }
                                    scan-btn-ta := TouchArea {
                                        clicked => {
                                            if (!root.wifi-scanning) {
                                                root.wifi-scan();
                                            }
                                        }
                                        mouse-cursor: pointer;
                                    }
                                }
                            }

                            // Connection status pill
                            Rectangle {
                                height: 24px;
                                border-radius: 12px;
                                background: root.wifi-current-ssid != ""
                                    ? Theme.success.transparentize(75%)
                                    : Theme.bg_light;

                                HorizontalLayout {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    spacing: 6px;
                                    alignment: center;

                                    Text {
                                        text: root.wifi-current-ssid != "" ? "●" : "○";
                                        color: root.wifi-current-ssid != ""
                                            ? Theme.success
                                            : Theme.fg_dim;
                                        font-size: 10px;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: root.wifi-current-ssid != ""
                                            ? ("Connected: " + root.wifi-current-ssid)
                                            : "Not connected";
                                        color: root.wifi-current-ssid != ""
                                            ? Theme.fg
                                            : Theme.fg_dim;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                        horizontal-stretch: 1;
                                    }
                                }
                            }

                            // Network list
                            wifi-list-flick := Flickable {
                                horizontal-stretch: 1;
                                vertical-stretch: 1;

                                VerticalLayout {
                                    spacing: 2px;

                                    for network[idx] in root.wifi-networks: Rectangle {
                                        height: 52px;
                                        border-radius: 5px;
                                        background: idx == root.wifi-selected-idx
                                            ? Theme.accent.transparentize(75%)
                                            : net-ta.has-hover
                                                ? Theme.bg_lighter
                                                : Theme.bg_light.transparentize(40%);

                                        HorizontalLayout {
                                            padding-left: 8px;
                                            padding-right: 8px;
                                            spacing: 8px;

                                            // Signal bars (bottom-aligned)
                                            VerticalLayout {
                                                alignment: center;
                                                width: 22px;
                                                SignalBars { signal: network.signal; }
                                            }

                                            // SSID + security
                                            VerticalLayout {
                                                horizontal-stretch: 1;
                                                alignment: center;
                                                spacing: 2px;

                                                Text {
                                                    text: network.ssid;
                                                    color: network.connected
                                                        ? Theme.accent
                                                        : Theme.fg;
                                                    font-size: 12px;
                                                    font-weight: network.connected ? 600 : 400;
                                                    overflow: elide;
                                                }
                                                Text {
                                                    text: network.security + (network.saved ? " · saved" : "");
                                                    color: Theme.fg_dim;
                                                    font-size: 10px;
                                                    overflow: elide;
                                                }
                                            }

                                            // Lock icon
                                            VerticalLayout {
                                                alignment: center;
                                                width: 18px;
                                                Text {
                                                    text: network.security != "Open" ? "🔒" : "";
                                                    font-size: 12px;
                                                    vertical-alignment: center;
                                                    horizontal-alignment: center;
                                                }
                                            }

                                            // Connected checkmark
                                            VerticalLayout {
                                                alignment: center;
                                                width: 16px;
                                                Text {
                                                    text: network.connected ? "✓" : "";
                                                    color: Theme.success;
                                                    font-size: 13px;
                                                    font-weight: 700;
                                                    vertical-alignment: center;
                                                    horizontal-alignment: center;
                                                }
                                            }
                                        }

                                        net-ta := TouchArea {
                                            clicked => {
                                                root.wifi-selected-idx = idx;
                                                root.wifi-password-input = "";
                                                root.wifi-show-password = false;
                                                root.wifi-qr-visible = false;
                                                root.wifi-qr-error = "";
                                            }
                                            mouse-cursor: pointer;
                                        }
                                    }

                                    // Empty state
                                    if root.wifi-networks.length == 0: Rectangle {
                                        height: 60px;
                                        VerticalLayout {
                                            alignment: center;
                                            Text {
                                                text: root.wifi-scanning
                                                    ? "Scanning for networks…"
                                                    : "No networks found.\nPress Scan to search.";
                                                color: Theme.fg_dim;
                                                font-size: 11px;
                                                horizontal-alignment: center;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        // List vertical scroll indicator
                        ScrollIndicator {
                            x: parent.width - 5px;
                            y: 0;
                            height: parent.height;
                            viewport-height: wifi-list-flick.viewport-height;
                            viewport-y: wifi-list-flick.viewport-y;
                            visible-height: wifi-list-flick.height;
                        }
                        // List horizontal scroll indicator
                        ScrollIndicatorH {
                            x: 0;
                            y: parent.height - 5px;
                            width: parent.width;
                            viewport-width: wifi-list-flick.viewport-width;
                            viewport-x: wifi-list-flick.viewport-x;
                            visible-width: wifi-list-flick.width;
                        }
                    }

                    // Vertical divider
                    Rectangle { width: 1px; background: Theme.bg_lighter; }

                    // ── Right: details + actions ──────────────────────────
                    Rectangle {
                        horizontal-stretch: 1;
                        vertical-stretch: 1;
                        clip: true;

                        wifi-detail-flick := Flickable {
                            width: parent.width - 6px;
                            height: parent.height;

                            VerticalLayout {
                                padding-left: 12px;
                                padding-right: 8px;
                                padding-top: 10px;
                                padding-bottom: 10px;
                                spacing: 10px;

                                // ─ Empty state ─────────────────────────────
                                if root.wifi-selected-idx < 0: VerticalLayout {
                                    alignment: center;
                                    spacing: 6px;
                                    Text {
                                        text: "📶";
                                        font-size: 32px;
                                        horizontal-alignment: center;
                                    }
                                    Text {
                                        text: "Select a network to connect,\nor use the QR section below.";
                                        color: Theme.fg_dim;
                                        font-size: 12px;
                                        horizontal-alignment: center;
                                        wrap: word-wrap;
                                    }
                                }

                                // ─ Network details (when something is selected) ─
                                if root.wifi-selected-idx >= 0 && root.wifi-selected-idx < root.wifi-networks.length: VerticalLayout {
                                    spacing: 10px;

                                    // Network name + security header
                                    Rectangle {
                                        border-radius: 6px;
                                        background: Theme.bg_light;

                                        VerticalLayout {
                                            padding: 12px;
                                            spacing: 4px;

                                            Text {
                                                text: root.wifi-networks[root.wifi-selected-idx].ssid;
                                                color: Theme.fg;
                                                font-size: 15px;
                                                font-weight: 700;
                                                overflow: elide;
                                            }
                                            HorizontalLayout {
                                                spacing: 8px;
                                                Text {
                                                    text: root.wifi-networks[root.wifi-selected-idx].security;
                                                    color: Theme.fg_dim;
                                                    font-size: 11px;
                                                    vertical-alignment: center;
                                                }
                                                Text {
                                                    text: "· " + root.wifi-networks[root.wifi-selected-idx].signal + "% signal";
                                                    color: Theme.fg_dim;
                                                    font-size: 11px;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }
                                    }

                                    // Password field (only for secured networks)
                                    if root.wifi-networks[root.wifi-selected-idx].security != "Open": Rectangle {
                                        border-radius: 6px;
                                        background: Theme.bg_light;

                                        VerticalLayout {
                                            padding: 12px;
                                            spacing: 8px;

                                            Text {
                                                text: "Password";
                                                color: Theme.fg_dim;
                                                font-size: 11px;
                                                font-weight: 600;
                                            }

                                            Rectangle {
                                                height: 32px;
                                                border-radius: 4px;
                                                background: Theme.bg_lighter;

                                                HorizontalLayout {
                                                    padding-left: 8px;
                                                    padding-right: 4px;
                                                    spacing: 4px;

                                                    wifi-pass-input := TextInput {
                                                        horizontal-stretch: 1;
                                                        color: Theme.fg;
                                                        font-size: 12px;
                                                        input-type: root.wifi-show-password
                                                            ? InputType.text
                                                            : InputType.password;
                                                        text <=> root.wifi-password-input;
                                                        accepted => {
                                                            root.wifi-connect(
                                                                root.wifi-selected-idx,
                                                                root.wifi-password-input,
                                                                0
                                                            );
                                                        }
                                                    }

                                                    // Show/hide toggle
                                                    Rectangle {
                                                        width: 28px;
                                                        height: 28px;
                                                        border-radius: 3px;
                                                        background: show-pass-ta.has-hover
                                                            ? Theme.bg_lighter
                                                            : transparent;
                                                        Text {
                                                            text: root.wifi-show-password ? "🙈" : "👁";
                                                            font-size: 13px;
                                                            vertical-alignment: center;
                                                            horizontal-alignment: center;
                                                        }
                                                        show-pass-ta := TouchArea {
                                                            clicked => {
                                                                root.wifi-show-password = !root.wifi-show-password;
                                                            }
                                                            mouse-cursor: pointer;
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }

                                    // Connect / Disconnect / Forget buttons
                                    HorizontalLayout {
                                        spacing: 8px;

                                        // Connect button (hidden when already connected to this network)
                                        if !root.wifi-networks[root.wifi-selected-idx].connected: Rectangle {
                                            horizontal-stretch: 1;
                                            height: 32px;
                                            border-radius: 4px;
                                            background: root.wifi-connecting
                                                ? Theme.accent.transparentize(60%)
                                                : conn-ta.has-hover
                                                    ? Theme.accent.transparentize(40%)
                                                    : Theme.accent.transparentize(70%);

                                            Text {
                                                text: root.wifi-connecting ? "Connecting…" : "Connect";
                                                color: Theme.fg;
                                                font-size: 12px;
                                                font-weight: 600;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                            conn-ta := TouchArea {
                                                clicked => {
                                                    if (!root.wifi-connecting) {
                                                        root.wifi-connect(
                                                            root.wifi-selected-idx,
                                                            root.wifi-password-input,
                                                            0
                                                        );
                                                    }
                                                }
                                                mouse-cursor: pointer;
                                            }
                                        }

                                        // Disconnect button (shown when connected to this network)
                                        if root.wifi-networks[root.wifi-selected-idx].connected: Rectangle {
                                            horizontal-stretch: 1;
                                            height: 32px;
                                            border-radius: 4px;
                                            background: disconn-ta.has-hover
                                                ? Theme.warning.transparentize(50%)
                                                : Theme.warning.transparentize(75%);

                                            Text {
                                                text: "Disconnect";
                                                color: Theme.fg;
                                                font-size: 12px;
                                                font-weight: 600;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                            disconn-ta := TouchArea {
                                                clicked => { root.wifi-disconnect(); }
                                                mouse-cursor: pointer;
                                            }
                                        }

                                        // Forget button (only for saved networks)
                                        if root.wifi-networks[root.wifi-selected-idx].saved: Rectangle {
                                            width: 70px;
                                            height: 32px;
                                            border-radius: 4px;
                                            background: forget-ta.has-hover
                                                ? Theme.danger.transparentize(50%)
                                                : Theme.danger.transparentize(80%);

                                            Text {
                                                text: "Forget";
                                                color: Theme.fg;
                                                font-size: 12px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                            forget-ta := TouchArea {
                                                clicked => {
                                                    root.wifi-forget(root.wifi-selected-idx);
                                                }
                                                mouse-cursor: pointer;
                                            }
                                        }
                                    }

                                    // Status text
                                    if root.wifi-status != "": Text {
                                        text: root.wifi-status;
                                        color: root.wifi-status-is-error
                                            ? Theme.danger
                                            : Theme.fg_dim;
                                        font-size: 11px;
                                        wrap: word-wrap;
                                    }

                                    // ─ Share via QR ─────────────────────────
                                    Rectangle { height: 1px; background: Theme.bg_lighter; }

                                    Text {
                                        text: "Share network via QR code";
                                        color: Theme.fg_dim;
                                        font-size: 11px;
                                        font-weight: 600;
                                    }

                                    // Generate / hide QR button
                                    HorizontalLayout {
                                        spacing: 8px;
                                        Rectangle {
                                            horizontal-stretch: 1;
                                            height: 30px;
                                            border-radius: 4px;
                                            background: gen-qr-ta.has-hover
                                                ? Theme.info.transparentize(50%)
                                                : Theme.info.transparentize(75%);

                                            Text {
                                                text: root.wifi-qr-visible ? "Hide QR" : "Generate QR";
                                                color: Theme.fg;
                                                font-size: 12px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                            gen-qr-ta := TouchArea {
                                                clicked => {
                                                    if root.wifi-qr-visible {
                                                        root.wifi-qr-visible = false;
                                                    } else {
                                                        root.wifi-generate-qr(root.wifi-selected-idx);
                                                    }
                                                }
                                                mouse-cursor: pointer;
                                            }
                                        }

                                        // Export button (only when QR is visible)
                                        if root.wifi-qr-visible: Rectangle {
                                            width: 80px;
                                            height: 30px;
                                            border-radius: 4px;
                                            background: export-ta.has-hover
                                                ? Theme.accent.transparentize(50%)
                                                : Theme.accent.transparentize(75%);

                                            Text {
                                                text: "Save SVG";
                                                color: Theme.fg;
                                                font-size: 11px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                            export-ta := TouchArea {
                                                clicked => {
                                                    root.wifi-export-qr(root.wifi-selected-idx);
                                                }
                                                mouse-cursor: pointer;
                                            }
                                        }
                                    }

                                    // QR code image
                                    if root.wifi-qr-visible: Rectangle {
                                        height: 220px;
                                        border-radius: 6px;
                                        background: #ffffff;

                                        HorizontalLayout {
                                            alignment: center;
                                            VerticalLayout {
                                                alignment: center;
                                                Image {
                                                    source: root.wifi-qr-image;
                                                    width: 200px;
                                                    height: 200px;
                                                    image-rendering: pixelated;
                                                }
                                            }
                                        }
                                    }

                                    // QR error text
                                    if root.wifi-qr-error != "": Rectangle {
                                        border-radius: 4px;
                                        background: Theme.danger.transparentize(80%);
                                        VerticalLayout {
                                            padding: 8px;
                                            Text {
                                                text: root.wifi-qr-error;
                                                color: Theme.danger;
                                                font-size: 11px;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }
                                }

                                // ─ Separator ───────────────────────────────
                                Rectangle { height: 1px; background: Theme.bg_lighter; }

                                // ─ Connect via QR (always shown) ───────────
                                Text {
                                    text: "Connect via QR code";
                                    color: Theme.fg_dim;
                                    font-size: 11px;
                                    font-weight: 600;
                                }

                                Text {
                                    text: "Paste a WIFI: URI from a QR scanner app, or scan an on-screen QR code.";
                                    color: Theme.fg_dim;
                                    font-size: 10px;
                                    wrap: word-wrap;
                                }

                                // URI input + Connect
                                Rectangle {
                                    height: 32px;
                                    border-radius: 4px;
                                    background: Theme.bg_light;

                                    HorizontalLayout {
                                        padding-left: 8px;
                                        padding-right: 4px;
                                        spacing: 4px;

                                        Rectangle {
                                            horizontal-stretch: 1;

                                            // Placeholder text overlay
                                            Text {
                                                visible: root.wifi-uri-input == "";
                                                text: "WIFI:T:WPA;S:MyNetwork;P:password;;";
                                                color: Theme.fg_dim;
                                                font-size: 10px;
                                                vertical-alignment: center;
                                            }

                                            wifi-uri-ti := TextInput {
                                                width: parent.width;
                                                color: Theme.fg;
                                                font-size: 11px;
                                                text <=> root.wifi-uri-input;
                                                accepted => {
                                                    if root.wifi-uri-input != "" {
                                                        root.wifi-apply-uri(root.wifi-uri-input);
                                                    }
                                                }
                                            }
                                        }

                                        Rectangle {
                                            width: 62px;
                                            height: 26px;
                                            border-radius: 3px;
                                            background: qr-conn-ta.has-hover
                                                ? Theme.accent.transparentize(40%)
                                                : Theme.accent.transparentize(70%);
                                            Text {
                                                text: "Connect";
                                                color: Theme.fg;
                                                font-size: 11px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                            qr-conn-ta := TouchArea {
                                                clicked => {
                                                    if root.wifi-uri-input != "" {
                                                        root.wifi-apply-uri(root.wifi-uri-input);
                                                    }
                                                }
                                                mouse-cursor: pointer;
                                            }
                                        }
                                    }
                                }

                                // Scan screen button
                                Rectangle {
                                    height: 30px;
                                    border-radius: 4px;
                                    background: scan-screen-ta.has-hover
                                        ? Theme.bg_lighter
                                        : Theme.bg_light;

                                    HorizontalLayout {
                                        padding-left: 8px;
                                        spacing: 6px;
                                        alignment: start;
                                        Text {
                                            text: "📷";
                                            font-size: 13px;
                                            vertical-alignment: center;
                                        }
                                        Text {
                                            text: "Scan on-screen QR code  (requires grim + zbarimg)";
                                            color: Theme.fg;
                                            font-size: 11px;
                                            vertical-alignment: center;
                                        }
                                    }
                                    scan-screen-ta := TouchArea {
                                        clicked => { root.wifi-scan-screenshot(); }
                                        mouse-cursor: pointer;
                                    }
                                }

                                // Status when no network is selected
                                if root.wifi-selected-idx < 0 && root.wifi-status != "": Text {
                                    text: root.wifi-status;
                                    color: root.wifi-status-is-error
                                        ? Theme.danger
                                        : Theme.fg_dim;
                                    font-size: 11px;
                                    wrap: word-wrap;
                                }

                                Rectangle { vertical-stretch: 1; }
                            }
                        }

                        ScrollIndicator {
                            x: parent.width - 5px;
                            y: 0;
                            height: parent.height;
                            viewport-height: wifi-detail-flick.viewport-height;
                            viewport-y: wifi-detail-flick.viewport-y;
                            visible-height: wifi-detail-flick.height;
                        }
                        ScrollIndicatorH {
                            x: 0;
                            y: parent.height - 5px;
                            width: parent.width;
                            viewport-width: wifi-detail-flick.viewport-width;
                            viewport-x: wifi-detail-flick.viewport-x;
                            visible-width: wifi-detail-flick.width;
                        }
                    }
                }
            }

            // ══════════════════════════════════════════════════════════════
            // STARTUP TAB
            // ══════════════════════════════════════════════════════════════

            if root.active-tab == 8: Rectangle {
                width: parent.width;
                height: parent.height;
                clip: true;

                tab8-flick := Flickable {
                    width: parent.width - 6px;
                    height: parent.height;
                    viewport-width: self.width;

                VerticalLayout {
                    padding-left: 10px;
                    padding-right: 4px;
                    spacing: 8px;

                    // ── Header ──
                    HorizontalLayout {
                        height: 32px;
                        spacing: 8px;

                        Text {
                            text: "Startup Apps & Services";
                            color: Theme.fg;
                            font-size: 14px;
                            font-weight: 600;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        // Add app button
                        Rectangle {
                            width: 80px;
                            height: 28px;
                            border-radius: 4px;
                            background: startup-add-touch.has-hover ? Theme.accent : Theme.accent.transparentize(20%);

                            Text {
                                text: "+ Add";
                                color: Theme.bg;
                                font-size: 12px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: 100%;
                                height: 100%;
                            }

                            startup-add-touch := TouchArea {
                                clicked => {
                                    root.startup-show-add-dialog = !root.startup-show-add-dialog;
                                    root.startup-filter-text = "";
                                    if root.startup-show-add-dialog {
                                        root.startup-filter-apps("");
                                    }
                                }
                                mouse-cursor: pointer;
                            }
                        }
                    }

                    // ── Status text ──
                    if root.startup-status-text != "": Text {
                        text: root.startup-status-text;
                        color: Theme.fg_dim;
                        font-size: 11px;
                    }

                    // ── Add app panel (inline) ──
                    if root.startup-show-add-dialog: Rectangle {
                        border-radius: 6px;
                        background: Theme.bg.mix(Theme.bg_light, 50%);
                        height: 320px;

                        VerticalLayout {
                            padding: 10px;
                            spacing: 6px;

                            // Header
                            HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    text: "Add to Startup";
                                    color: Theme.fg;
                                    font-size: 13px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }

                                Rectangle {
                                    width: 24px;
                                    height: 24px;
                                    border-radius: 4px;
                                    background: startup-close-add-touch.has-hover ? Theme.bg_lighter : transparent;

                                    Text {
                                        text: "\u{2715}";
                                        color: Theme.fg_dim;
                                        font-size: 12px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        width: 100%;
                                        height: 100%;
                                    }

                                    startup-close-add-touch := TouchArea {
                                        clicked => {
                                            root.startup-show-add-dialog = false;
                                        }
                                        mouse-cursor: pointer;
                                    }
                                }
                            }

                            // Search filter
                            Rectangle {
                                height: 28px;
                                border-radius: 4px;
                                background: Theme.bg_light;

                                startup-filter-input := TextInput {
                                    x: 8px;
                                    y: 0;
                                    width: parent.width - 16px;
                                    height: parent.height;
                                    color: Theme.fg;
                                    font-size: 12px;
                                    text: root.startup-filter-text;
                                    edited => {
                                        root.startup-filter-text = self.text;
                                        root.startup-filter-apps(self.text);
                                    }
                                }

                                if root.startup-filter-text == "": Text {
                                    x: 8px;
                                    y: 0;
                                    height: parent.height;
                                    text: "Search apps...";
                                    color: Theme.fg_dim;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                }
                            }

                            // Available apps list
                            Flickable {
                                vertical-stretch: 1;

                                VerticalLayout {
                                    spacing: 2px;

                                    for app[idx] in root.startup-available-apps: Rectangle {
                                        height: 36px;
                                        border-radius: 4px;
                                        background: startup-app-touch.has-hover ? Theme.accent.transparentize(70%) : transparent;

                                        startup-app-touch := TouchArea {
                                            mouse-cursor: pointer;
                                        }

                                        HorizontalLayout {
                                            padding-left: 8px;
                                            padding-right: 8px;
                                            spacing: 8px;

                                            VerticalLayout {
                                                alignment: center;
                                                horizontal-stretch: 1;
                                                spacing: 1px;

                                                Text {
                                                    text: app.name;
                                                    color: Theme.fg;
                                                    font-size: 12px;
                                                    overflow: elide;
                                                }

                                                if app.description != "": Text {
                                                    text: app.description;
                                                    color: Theme.fg_dim;
                                                    font-size: 9px;
                                                    overflow: elide;
                                                }
                                            }

                                            VerticalLayout {
                                                alignment: center;
                                                width: 40px;

                                                Rectangle {
                                                    width: 36px;
                                                    height: 22px;
                                                    border-radius: 4px;
                                                    background: startup-app-add-touch.has-hover ? Theme.accent : Theme.accent.transparentize(30%);

                                                    Text {
                                                        text: "Add";
                                                        color: Theme.bg;
                                                        font-size: 10px;
                                                        font-weight: 600;
                                                        horizontal-alignment: center;
                                                        vertical-alignment: center;
                                                        width: 100%;
                                                        height: 100%;
                                                    }

                                                    startup-app-add-touch := TouchArea {
                                                        clicked => {
                                                            root.startup-add(idx);
                                                            root.startup-show-add-dialog = false;
                                                        }
                                                        mouse-cursor: pointer;
                                                    }
                                                }
                                            }
                                        }
                                    }

                                    if root.startup-available-apps.length == 0: Text {
                                        text: "No apps found";
                                        color: Theme.fg_dim;
                                        font-size: 12px;
                                        horizontal-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    // ── Startup items list ──
                    for item[idx] in root.startup-items: Rectangle {
                        height: 52px;
                        border-radius: 6px;
                        background: startup-item-touch.has-hover ? Theme.bg_lighter : Theme.bg_light;

                        startup-item-touch := TouchArea {
                            mouse-cursor: default;
                        }

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 10px;

                            // Source badge
                            VerticalLayout {
                                alignment: center;
                                width: 18px;
                                Text {
                                    text: item.source == "hyprland" ? "\u{2699}" :
                                          item.source == "systemd"  ? "\u{26A1}" :
                                          "\u{1F4E6}";
                                    font-size: 14px;
                                    horizontal-alignment: center;
                                    color: Theme.fg_dim;
                                }
                            }

                            // Name + description
                            VerticalLayout {
                                alignment: center;
                                horizontal-stretch: 1;
                                spacing: 2px;

                                Text {
                                    text: item.name;
                                    color: Theme.fg;
                                    font-size: 13px;
                                    font-weight: 500;
                                    overflow: elide;
                                }

                                if item.description != "": Text {
                                    text: item.description;
                                    color: Theme.fg_dim;
                                    font-size: 10px;
                                    overflow: elide;
                                }
                            }

                            // Source label
                            VerticalLayout {
                                alignment: center;
                                width: 60px;
                                Text {
                                    text: item.source;
                                    color: Theme.fg_dim;
                                    font-size: 9px;
                                    horizontal-alignment: center;
                                }
                            }

                            // Toggle switch
                            VerticalLayout {
                                alignment: center;
                                width: 42px;

                                Rectangle {
                                    width: 38px;
                                    height: 20px;
                                    border-radius: 10px;
                                    background: item.enabled
                                        ? Theme.accent
                                        : Theme.bg_lighter;
                                    opacity: item.toggleable ? 1.0 : 0.4;

                                    // Knob
                                    Rectangle {
                                        x: item.enabled ? parent.width - self.width - 2px : 2px;
                                        y: 2px;
                                        width: 16px;
                                        height: 16px;
                                        border-radius: 8px;
                                        background: item.enabled
                                            ? Theme.bg
                                            : Theme.fg_dim;
                                    }

                                    if item.toggleable: TouchArea {
                                        clicked => {
                                            root.startup-toggle(idx, !item.enabled);
                                        }
                                        mouse-cursor: pointer;
                                    }
                                }
                            }

                            // Remove button (only for xdg entries — user-added)
                            if item.source == "xdg": VerticalLayout {
                                alignment: center;
                                width: 24px;

                                Rectangle {
                                    width: 22px;
                                    height: 22px;
                                    border-radius: 4px;
                                    background: startup-rm-touch.has-hover ? Theme.danger.transparentize(50%) : transparent;

                                    Text {
                                        text: "\u{2715}";
                                        color: startup-rm-touch.has-hover ? Theme.danger : Theme.fg_dim;
                                        font-size: 11px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        width: 100%;
                                        height: 100%;
                                    }

                                    startup-rm-touch := TouchArea {
                                        clicked => {
                                            root.startup-remove(idx);
                                        }
                                        mouse-cursor: pointer;
                                    }
                                }
                            }
                        }
                    }

                    // ── Empty state ──
                    if root.startup-items.length == 0: Rectangle {
                        height: 80px;
                        VerticalLayout {
                            alignment: center;
                            Text {
                                text: "No startup items found";
                                color: Theme.fg_dim;
                                font-size: 13px;
                                horizontal-alignment: center;
                            }
                        }
                    }

                    // Bottom spacer
                    Rectangle { height: 20px; }

                } // VerticalLayout
                } // Flickable

                ScrollIndicator {
                    x: parent.width - 5px;
                    y: 0;
                    height: parent.height;
                    viewport-height: tab8-flick.viewport-height;
                    viewport-y: tab8-flick.viewport-y;
                    visible-height: tab8-flick.height;
                }
            }

            } // ← close tab content wrapper
        }
    }

    // ── Help overlay ─────────────────────────────────────────────────────────

    Rectangle {
        visible: root.show-help;
        width: 100%;
        height: 100%;
        background: Theme.bg;

        Flickable {
            width: parent.width;
            height: parent.height;
            viewport-width: self.width;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;
                alignment: start;

                VerticalLayout {
                    spacing: 3px;
                    alignment: center;
                    Text {
                        text: "Settings";
                        color: Theme.accent;
                        font-size: 20px;
                        font-weight: 700;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: root.app-version;
                        color: Theme.fg_dim;
                        font-size: 12px;
                        horizontal-alignment: center;
                    }
                }

                Rectangle {
                    border-radius: 6px;
                    background: Theme.bg_light;
                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;
                        Text {
                            text: "Keyboard shortcuts";
                            color: Theme.accent;
                            font-size: 13px;
                            font-weight: 600;
                        }
                        Text {
                            text: "1-9       Switch tabs\nCtrl+F  Search settings\nAlt+C   Open layout dropdown\nAlt+A   Add selected layout\nAlt+D   Remove second layout\nAlt+I    Identify monitors\nAlt+R   Refresh monitors\nAlt+P   Set primary monitor\nEsc      Close overlay / app\n?         Toggle this Help";
                            color: Theme.fg;
                            font-size: 12px;
                            wrap: word-wrap;
                        }
                    }
                }

                Text {
                    text: "Part of smplOS";
                    color: Theme.fg_dim;
                    font-size: 11px;
                    horizontal-alignment: center;
                }

                Rectangle { vertical-stretch: 1; }
            }
        }
    }

    // ── Inline search results dropdown ─────────────────────────────────────────

    if root.search-results.length > 0 && root.global-search-text != "": Rectangle {
        x: root.width - 12px - 260px;
        y: 44px;
        width: 260px;
        height: min(280px, root.search-results.length * 34px + 8px);
        border-radius: 6px;
        background: Theme.bg_light;
        clip: true;

        // Prevent clicks from falling through
        TouchArea {}

        Flickable {
            width: parent.width;
            height: parent.height;

            VerticalLayout {
                spacing: 0px;
                padding: 4px;

                for result[idx] in root.search-results: Rectangle {
                    height: 30px;
                    border-radius: 4px;
                    background: idx == root.search-selected-index ? Theme.accent :
                                sr-touch.has-hover ? Theme.bg_lighter : transparent;

                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;

                        VerticalLayout {
                            alignment: center;
                            horizontal-stretch: 1;
                            Text {
                                text: result.label;
                                color: idx == root.search-selected-index ? Theme.bg : Theme.fg;
                                font-size: 12px;
                                overflow: elide;
                            }
                        }

                        VerticalLayout {
                            alignment: center;
                            Text {
                                text: result.tab-name;
                                color: idx == root.search-selected-index ? Theme.bg : Theme.fg_dim;
                                font-size: 10px;
                            }
                        }
                    }

                    sr-touch := TouchArea {
                        clicked => {
                            root.active-tab = result.tab-index;
                            root.global-search-text = "";
                            root.filter-search("");
                            focus-scope.focus();
                        }
                        mouse-cursor: pointer;
                    }
                }
            }
        }
    }

    // ── Keyboard layout dropdown overlay ─────────────────────────────────────

    Rectangle {
        visible: root.dropdown-open && !root.show-help && root.active-tab == 1;
        width: 100%;
        height: 100%;

        TouchArea {
            clicked => {
                root.dropdown-open = false;
                focus-scope.focus();
            }
        }

        Rectangle {
            x: 160px;
            y: 91px;
            width: root.width - 170px;
            height: 200px;
            border-radius: 4px;
            background: Theme.bg_light;
            border-width: 1px;
            border-color: Theme.bg_lighter;
            drop-shadow-blur: 12px;
            drop-shadow-color: #00000080;
            drop-shadow-offset-y: 4px;

            VerticalLayout {
                padding: 4px;
                spacing: 2px;

                Rectangle {
                    height: 28px;
                    border-radius: 4px;
                    background: Theme.bg;

                    search-input := TextInput {
                        x: 8px;
                        y: 6px;
                        width: parent.width - 16px;
                        height: parent.height;
                        color: Theme.fg;
                        font-size: 12px;
                        text <=> root.search-text;
                        edited => {
                            root.filter-layouts(self.text);
                            root.highlighted-dropdown-index = 0;
                            dropdown-flick.viewport-y = 0;
                        }
                        key-pressed(e) => {
                            if e.text == Key.DownArrow {
                                if root.highlighted-dropdown-index < root.available-layouts.length - 1 {
                                    root.highlighted-dropdown-index += 1;
                                }
                                dropdown-flick.viewport-y = -root.highlighted-dropdown-index * 27px + 80px;
                                return accept;
                            }
                            if e.text == Key.UpArrow {
                                if root.highlighted-dropdown-index > 0 {
                                    root.highlighted-dropdown-index -= 1;
                                }
                                dropdown-flick.viewport-y = -root.highlighted-dropdown-index * 27px + 80px;
                                return accept;
                            }
                            if e.text == Key.Return {
                                if root.available-layouts.length > 0 {
                                    root.selected-dropdown-index = root.highlighted-dropdown-index;
                                    root.dropdown-open = false;
                                    root.add-layout(root.highlighted-dropdown-index);
                                    focus-scope.focus();
                                }
                                return accept;
                            }
                            if e.text == Key.Escape {
                                root.dropdown-open = false;
                                focus-scope.focus();
                                return accept;
                            }
                            reject
                        }
                    }

                    Text {
                        visible: root.search-text == "";
                        x: 8px;
                        y: 6px;
                        height: parent.height;
                        text: "Search layouts...";
                        color: Theme.fg_dim;
                        font-size: 12px;
                        vertical-alignment: center;
                    }
                }

                dropdown-flick := Flickable {
                    VerticalLayout {
                        spacing: 1px;
                        for item[idx] in root.available-layouts: Rectangle {
                            height: 26px;
                            border-radius: 3px;
                            background: idx == root.highlighted-dropdown-index
                                ? Theme.accent.transparentize(50%)
                                : item-touch.has-hover ? Theme.accent.transparentize(70%) : transparent;

                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 8px;
                                Text {
                                    text: item;
                                    color: idx == root.selected-dropdown-index ? Theme.accent : Theme.fg;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                            }

                            item-touch := TouchArea {
                                moved => {
                                    root.highlighted-dropdown-index = idx;
                                }
                                clicked => {
                                    root.selected-dropdown-index = idx;
                                    root.dropdown-open = false;
                                    root.add-layout(idx);
                                    focus-scope.focus();
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // ── Dictation language dropdown overlay ───────────────────────────────────

    Rectangle {
        visible: root.dictation-lang-dropdown-open && root.active-tab == 2;
        width: 100%;
        height: 100%;

        TouchArea {
            clicked => {
                root.dictation-lang-dropdown-open = false;
                focus-scope.focus();
            }
        }

        Rectangle {
            x: 160px;
            y: 91px;
            width: root.width - 170px;
            height: 200px;
            border-radius: 4px;
            background: Theme.bg_light;
            border-width: 1px;
            border-color: Theme.bg_lighter;
            drop-shadow-blur: 12px;
            drop-shadow-color: #00000080;
            drop-shadow-offset-y: 4px;

            VerticalLayout {
                padding: 4px;
                spacing: 2px;

                Rectangle {
                    height: 28px;
                    border-radius: 4px;
                    background: Theme.bg;

                    dictation-lang-search-input := TextInput {
                        x: 8px;
                        y: 6px;
                        width: parent.width - 16px;
                        height: parent.height;
                        color: Theme.fg;
                        font-size: 12px;
                        text <=> root.dictation-lang-search;
                        edited => {
                            root.filter-dictation-langs(self.text);
                            root.dictation-lang-highlighted-idx = 0;
                            dict-lang-flick.viewport-y = 0;
                        }
                        key-pressed(e) => {
                            if e.text == Key.DownArrow {
                                if root.dictation-lang-highlighted-idx < root.dictation-lang-list.length - 1 {
                                    root.dictation-lang-highlighted-idx += 1;
                                }
                                dict-lang-flick.viewport-y = -root.dictation-lang-highlighted-idx * 27px + 80px;
                                return accept;
                            }
                            if e.text == Key.UpArrow {
                                if root.dictation-lang-highlighted-idx > 0 {
                                    root.dictation-lang-highlighted-idx -= 1;
                                }
                                dict-lang-flick.viewport-y = -root.dictation-lang-highlighted-idx * 27px + 80px;
                                return accept;
                            }
                            if e.text == Key.Return {
                                if root.dictation-lang-list.length > 0 {
                                    root.select-dictation-lang(root.dictation-lang-highlighted-idx);
                                    root.dictation-lang-dropdown-open = false;
                                    focus-scope.focus();
                                }
                                return accept;
                            }
                            if e.text == Key.Escape {
                                root.dictation-lang-dropdown-open = false;
                                focus-scope.focus();
                                return accept;
                            }
                            reject
                        }
                    }

                    Text {
                        visible: root.dictation-lang-search == "";
                        x: 8px;
                        y: 6px;
                        height: parent.height;
                        text: "Search languages...";
                        color: Theme.fg_dim;
                        font-size: 12px;
                        vertical-alignment: center;
                    }
                }

                dict-lang-flick := Flickable {
                    VerticalLayout {
                        spacing: 1px;
                        for item[idx] in root.dictation-lang-list: Rectangle {
                            height: 26px;
                            border-radius: 3px;
                            background: idx == root.dictation-lang-highlighted-idx
                                ? Theme.accent.transparentize(50%)
                                : dict-lang-touch.has-hover ? Theme.accent.transparentize(70%) : transparent;

                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 8px;
                                Text {
                                    text: item;
                                    color: Theme.fg;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                            }

                            dict-lang-touch := TouchArea {
                                moved => {
                                    root.dictation-lang-highlighted-idx = idx;
                                }
                                clicked => {
                                    root.select-dictation-lang(idx);
                                    root.dictation-lang-dropdown-open = false;
                                    focus-scope.focus();
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // ── Loading spinner ──────────────────────────────────────────────────────

    if root.loading && root.active-tab == 1: Rectangle {
        width: 100%;
        height: 100%;
        background: Theme.bg.transparentize(30%);

        VerticalLayout {
            alignment: center;
            HorizontalLayout {
                alignment: center;
                Text {
                    text: "Loading layouts...";
                    color: Theme.fg_dim;
                    font-size: 13px;
                    horizontal-alignment: center;
                }
            }
        }
    }

}
